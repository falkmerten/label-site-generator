{% extends "base.njk" %}

{% block title %}Releases — {{ labelName }}{% endblock %}
{% block title2 %}Releases — {{ labelName }}{% endblock %}
{% block metaDescription %}All releases on {{ labelName }} — browse the full discography.{% endblock %}
{% block ogDescription %}All releases on {{ labelName }} — browse the full discography.{% endblock %}
{% block twitterTitle %}Releases — {{ labelName }}{% endblock %}
{% block twitterDescription %}All releases on {{ labelName }} — browse the full discography.{% endblock %}

{% block jsonLd %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Releases",
  "description": "All releases on {{ labelName }}"{% if canonicalUrl %},
  "url": {{ canonicalUrl | dump | safe }}{% endif %}
}
</script>
{% endblock %}

{% block content %}
  <div class="releases-page">
    <div class="releases-page-inner">
      <h1>Releases</h1>
      {% if allAlbums and allAlbums.length %}
        <div class="release-grid">
          {% for album in allAlbums %}
            {% if album.tier == 'announce' %}
            <div class="release-card{% if album.releaseDate | isFuture %} release-coming-soon{% endif %}">
            {% else %}
            <a href="{{ rootPath }}artists/{{ album.artistSlug }}/{{ album.slug }}/" class="release-card{% if album.releaseDate | isFuture %} release-coming-soon{% endif %}">
            {% endif %}
              {% if album.releaseDate | isFuture %}<span class="coming-soon-badge">Coming Soon</span>{% endif %}
              {% if album.artwork | isLocal %}
                <picture>
                  <source srcset="{{ rootPath }}artists/{{ album.artistSlug }}/{{ album.slug }}/{{ album.artwork | toMobileWebp }}" media="(max-width: 640px)" type="image/webp">
                  <source srcset="{{ rootPath }}artists/{{ album.artistSlug }}/{{ album.slug }}/{{ album.artwork | toWebp }}" type="image/webp">
                  <img src="{{ rootPath }}artists/{{ album.artistSlug }}/{{ album.slug }}/{{ album.artwork }}" alt="{{ album.title }}" loading="lazy">
                </picture>
              {% elif album.artwork %}
                <img src="{{ album.artwork }}" alt="{{ album.title }}" loading="lazy">
              {% else %}
                <div class="artwork-placeholder"></div>
              {% endif %}
              <div class="card-body">
                <span class="release-artist">{{ album.artistName }}</span>
                <span class="release-title">{{ album.title }}</span>
                {% if album.releaseDate %}
                  <span class="release-year">{{ album.releaseDate | formatDate }}</span>
                {% endif %}
                {% set formats = album | availableFormats %}
                {% if formats %}<span class="release-formats">({{ formats }})</span>{% endif %}
              </div>
            {% if album.tier == 'announce' %}
            </div>
            {% else %}
            </a>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <p>No releases currently available.</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
