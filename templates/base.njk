<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ labelName }}{% endblock %}</title>

  {# Canonical URL #}
  {% if canonicalUrl %}<link rel="canonical" href="{{ canonicalUrl }}">{% endif %}

  {# Meta description #}
  <meta name="description" content="{% block metaDescription %}{{ labelName }} — independent music label.{% endblock %}">

  {# Open Graph #}
  <meta property="og:type" content="{% block ogType %}website{% endblock %}">
  <meta property="og:site_name" content="{{ labelName }}">
  <meta property="og:title" content="{% block ogTitle %}{% block title2 %}{{ labelName }}{% endblock %}{% endblock %}">
  <meta property="og:description" content="{% block ogDescription %}{{ labelName }} — independent music label.{% endblock %}">
  {% if canonicalUrl %}<meta property="og:url" content="{{ canonicalUrl }}">{% endif %}
  {% block ogImage %}
    {% if siteUrl %}<meta property="og:image" content="{{ siteUrl }}banner.jpg">{% endif %}
  {% endblock %}

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{% block twitterTitle %}{{ labelName }}{% endblock %}">
  <meta name="twitter:description" content="{% block twitterDescription %}{{ labelName }} — independent music label.{% endblock %}">
  {% block twitterImage %}
    {% if siteUrl %}<meta name="twitter:image" content="{{ siteUrl }}banner.jpg">{% endif %}
  {% endblock %}

  {# JSON-LD structured data #}
  {% block jsonLd %}{% endblock %}

  <link rel="stylesheet" href="{{ rootPath }}style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">

  {# Google Analytics 4 — only injected when GA_MEASUREMENT_ID is set #}
  {% if gaMeasurementId %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ gaMeasurementId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ gaMeasurementId }}');
  </script>
  {% endif %}
</head>
<body>

  <!-- Banner + overlapping logo hero -->
  {% block hero %}
  <div class="site-hero">
    <img src="{{ rootPath }}banner.jpg" alt="{{ labelName }}" class="site-hero-banner">
    <a href="{{ rootPath }}">
      <img src="{{ rootPath }}logo-round.png" alt="{{ labelName }} Logo" class="site-hero-logo">
    </a>
  </div>
  {% endblock %}

  <!-- Sticky nav bar -->
  <header class="site-header">
    <div class="header-inner">
      <nav class="site-nav">
        <div class="nav-item has-dropdown">
          <a href="{{ rootPath }}#artists"><i class="fa-solid fa-users"></i> Artists</a>
          {% if artists and artists.length %}
          <div class="dropdown">
            {% for artist in artists %}
              <a href="{{ rootPath }}artists/{{ artist.slug }}/">{{ artist.name }}</a>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        <a href="{{ rootPath }}releases/" class="nav-item"><i class="fa-solid fa-record-vinyl"></i> Releases</a>
        {% for p in mainNavPages %}
          <a href="{{ rootPath }}{{ p.slug }}/" class="nav-item">{{ p.title }}</a>
        {% endfor %}
      </nav>
      <button class="nav-toggle" aria-label="Toggle navigation">&#9776;</button>
    </div>
  </header>

  <!-- Spacer so content clears the overlapping logo -->
  <div class="hero-spacer"></div>

  <main>
    {% block content %}{% endblock %}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-legal">
        <p>&copy; {{ currentYear }} {{ labelName }}</p>
      </div>
      <div class="footer-right">
        <nav class="footer-social">
          {% if social.bandcamp %}<a href="{{ social.bandcamp }}" target="_blank" rel="noopener noreferrer" aria-label="Bandcamp"><i class="fa-brands fa-bandcamp"></i></a>{% endif %}
          {% if social.spotify %}<a href="{{ social.spotify }}" target="_blank" rel="noopener noreferrer" aria-label="Spotify"><i class="fa-brands fa-spotify"></i></a>{% endif %}
          {% if social.soundcloud %}<a href="{{ social.soundcloud }}" target="_blank" rel="noopener noreferrer" aria-label="SoundCloud"><i class="fa-brands fa-soundcloud"></i></a>{% endif %}
          {% if social.youtube %}<a href="{{ social.youtube }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>{% endif %}
          {% if social.instagram %}<a href="{{ social.instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>{% endif %}
          {% if social.facebook %}<a href="{{ social.facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><i class="fa-brands fa-facebook"></i></a>{% endif %}
          {% if social.tiktok %}<a href="{{ social.tiktok }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok"><i class="fa-brands fa-tiktok"></i></a>{% endif %}
          {% if social.twitter %}<a href="{{ social.twitter }}" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter"><i class="fa-brands fa-x-twitter"></i></a>{% endif %}
        </nav>
        <nav class="footer-nav">
          {% for p in footerNavPages %}
            <a href="{{ rootPath }}{{ p.slug }}/">{{ p.title }}</a>
          {% endfor %}
        </nav>
      </div>
    </div>
  </footer>

  <script>
    // Mobile nav toggle
    document.querySelector('.nav-toggle').addEventListener('click', function() {
      document.querySelector('.site-nav').classList.toggle('open');
    });
    // Mobile: tap on dropdown parent toggles it
    document.querySelectorAll('.has-dropdown > a').forEach(function(el) {
      el.addEventListener('click', function(e) {
        if (window.innerWidth <= 640) {
          e.preventDefault();
          var dd = el.nextElementSibling;
          if (dd) dd.style.display = dd.style.display === 'block' ? 'none' : 'block';
        }
      });
    });
  </script>
</body>
</html>
