{% extends "base.njk" %}

{% block title %}{{ labelName }}{% endblock %}
{% block metaDescription %}{{ labelName }} — independent music label. Artists, releases and more.{% endblock %}
{% block ogDescription %}{{ labelName }} — independent music label. Artists, releases and more.{% endblock %}
{% block twitterDescription %}{{ labelName }} — independent music label. Artists, releases and more.{% endblock %}

{% block jsonLd %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ labelName | dump | safe }},
  {% if canonicalUrl %}"url": {{ canonicalUrl | dump | safe }},{% endif %}
  "description": "{{ labelName }} — independent music label"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  "name": "Main Navigation",
  "hasPart": [
    { "@type": "WebPage", "name": "Releases", "url": "{{ siteUrl }}releases/" }{% if hasNews %},
    { "@type": "WebPage", "name": "News", "url": "{{ siteUrl }}news/" }{% endif %}{% for p in footerNavPages %},
    { "@type": "WebPage", "name": "{{ p.title }}", "url": "{{ siteUrl }}{{ p.slug }}/" }{% endfor %}
  ]
}
</script>
{% endblock %}

{% block content %}

  <section id="artists" class="section artists-section">
    <div class="section-inner">
      <h2>Artists</h2>
      {% if artists and artists.length %}
        <div class="artist-grid">
          {% for artist in artists %}
            <a href="{{ rootPath }}artists/{{ artist.slug }}/" class="artist-card">
              {% if artist.photo | isLocal %}
                <picture>
                  <source srcset="{{ rootPath }}artists/{{ artist.slug }}/{{ artist.photo | toMobileWebp }}" media="(max-width: 640px)" type="image/webp">
                  <source srcset="{{ rootPath }}artists/{{ artist.slug }}/{{ artist.photo | toWebp }}" type="image/webp">
                  <img src="{{ rootPath }}artists/{{ artist.slug }}/{{ artist.photo }}" alt="{{ artist.name }}" loading="lazy">
                </picture>
              {% elif artist.photo %}
                <img src="{{ artist.photo }}" alt="{{ artist.name }}" loading="lazy">
              {% else %}
                <div class="artwork-placeholder"></div>
              {% endif %}
              <div class="card-body">
                <span class="artist-name">{{ artist.name }}</span>
                {% if artist.location %}<span class="artist-location">{{ artist.location }}</span>{% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <p>No artists currently listed.</p>
      {% endif %}
    </div>
  </section>

  <section id="releases" class="section releases-section">
    <div class="section-inner">
      <h2>Latest Releases</h2>
      {% if latestReleases and latestReleases.length %}
        <div class="release-grid">
          {% for album in latestReleases %}
            <a href="{{ rootPath }}artists/{{ album.artistSlug }}/{{ album.slug }}/" class="release-card{% if album.releaseDate | isFuture %} release-coming-soon{% endif %}">
              {% if album.releaseDate | isFuture %}<span class="coming-soon-badge">Coming Soon</span>{% endif %}
              {% if album.artwork | isLocal %}
                <picture>
                  <source srcset="{{ rootPath }}artists/{{ album.artistSlug }}/{{ album.slug }}/{{ album.artwork | toMobileWebp }}" media="(max-width: 640px)" type="image/webp">
                  <source srcset="{{ rootPath }}artists/{{ album.artistSlug }}/{{ album.slug }}/{{ album.artwork | toWebp }}" type="image/webp">
                  <img src="{{ rootPath }}artists/{{ album.artistSlug }}/{{ album.slug }}/{{ album.artwork }}" alt="{{ album.title }}" loading="lazy">
                </picture>
              {% elif album.artwork %}
                <img src="{{ album.artwork }}" alt="{{ album.title }}" loading="lazy">
              {% else %}
                <img src="{{ rootPath }}artwork-placeholder.svg" alt="{{ album.title }}" loading="lazy">
              {% endif %}
              <div class="card-body">
                <span class="release-artist">{{ album.artistName }}</span>
                <span class="release-title">{{ album.title }}</span>
                {% if album.releaseDate %}<span class="release-year">{{ album.releaseDate | formatDate }}</span>{% endif %}
                {% set formats = album | availableFormats %}
                {% if formats %}<span class="release-formats">({{ formats }})</span>{% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
        {% if totalReleases > 12 %}
          <div class="view-all">
            <a href="{{ rootPath }}releases/">View all {{ totalReleases }} releases</a>
          </div>
        {% endif %}
      {% else %}
        <p>No releases currently available.</p>
      {% endif %}
    </div>
  </section>

  <section id="news" class="section news-section">
    <div class="section-inner">
      <h2>News</h2>
      {% if hasNews %}
        <div class="news-list">
          {% for article in newsArticles %}
            <article class="news-item">
              {% if article.imageUrl %}
                <a href="{{ rootPath }}news/{{ article.slug }}/" class="news-item-image">
                  {% if article.imageUrl | isLocal %}
                  <picture>
                    <source srcset="{{ rootPath }}news/{{ article.slug }}/{{ article.imageUrl | toMobileWebp }}" media="(max-width: 640px)" type="image/webp">
                    <source srcset="{{ rootPath }}news/{{ article.slug }}/{{ article.imageUrl | toWebp }}" type="image/webp">
                    <img src="{{ rootPath }}news/{{ article.slug }}/{{ article.imageUrl }}" alt="{{ article.title }}" loading="lazy">
                  </picture>
                  {% else %}
                  <img src="{{ article.imageUrl }}" alt="{{ article.title }}" loading="lazy">
                  {% endif %}
                </a>
              {% endif %}
              <div class="news-item-body">
                <h3 class="news-item-title"><a href="{{ rootPath }}news/{{ article.slug }}/">{{ article.title }}</a></h3>
                <time class="news-item-date" datetime="{{ article.date }}">{{ article.date | formatDate }}</time>
                <p class="news-item-excerpt">{{ article.excerpt }}</p>
                <a href="{{ rootPath }}news/{{ article.slug }}/" class="news-item-more">Read more &rarr;</a>
              </div>
            </article>
          {% endfor %}
        </div>
        {% if totalNews > 10 %}
          <div class="view-all">
            <a href="{{ rootPath }}news/">View all {{ totalNews }} articles</a>
          </div>
        {% endif %}
      {% elif newsHtml %}
        <div class="prose">{{ newsHtml | safe }}</div>
      {% endif %}
      {% if newsletter.actionUrl %}
        <div class="newsletter-form" id="newsletter-wrapper">
          <form id="newsletter-form" class="newsletter">
            <h3>Stay in the loop</h3>
            <div class="newsletter-fields">
              <div class="newsletter-field">
                <label for="nl-name">Name</label>
                <input type="text" name="name" id="nl-name" placeholder="Your name">
              </div>
              <div class="newsletter-field">
                <label for="nl-email">Email</label>
                <input type="email" name="email" id="nl-email" placeholder="Your email" required>
              </div>
              <button type="submit" class="btn newsletter-btn">Subscribe</button>
            </div>
            <div class="newsletter-consent">
              <label>
                <input type="checkbox" name="gdpr" id="nl-gdpr" required>
                <span>I consent to receiving email updates from {{ labelName }}. You can unsubscribe at any time.</span>
              </label>
            </div>
            <div style="display:none">
              <input type="text" name="hp" id="nl-hp">
            </div>
          </form>
          <div id="newsletter-msg" class="newsletter-msg" style="display:none"></div>
          <script>
            document.getElementById('newsletter-form').addEventListener('submit', function(e) {
              e.preventDefault();
              var form = this;
              var msg = document.getElementById('newsletter-msg');
              var data = new FormData();
              data.append('name', document.getElementById('nl-name').value);
              data.append('email', document.getElementById('nl-email').value);
              data.append('gdpr', document.getElementById('nl-gdpr').checked ? 'on' : '');
              data.append('hp', document.getElementById('nl-hp').value);
              {% if newsletter.listId %}data.append('list', '{{ newsletter.listId }}');{% endif %}
              data.append('subform', 'yes');
              fetch('{{ newsletter.actionUrl }}', { method: 'POST', body: data, mode: 'no-cors' })
                .then(function() {
                  document.getElementById('newsletter-form').style.display = 'none';
                  msg.style.display = 'block';
                  {% if newsletter.doubleOptIn %}
                  msg.textContent = 'Almost there! Please check your email and confirm your subscription.';
                  {% else %}
                  msg.textContent = 'Successfully subscribed!';
                  {% endif %}
                  msg.className = 'newsletter-msg newsletter-success';
                })
                .catch(function() {
                  msg.style.display = 'block';
                  msg.textContent = 'Something went wrong. Please try again.';
                  msg.className = 'newsletter-msg newsletter-error';
                });
            });
          </script>
        </div>
      {% elif not newsHtml %}
        <div class="news-placeholder">
          <p>Join our mailing list for the latest news</p>
          <a href="{{ rootPath }}contact/" class="btn">Sign Up</a>
        </div>
      {% endif %}
    </div>
  </section>

  {% if hasEvents %}
  <section id="shows" class="section shows-section">
    <div class="section-inner">
      <h2>Upcoming Shows</h2>
      <div class="events-list">
        {% for event in allEvents %}
          <div class="event-row">
            <span class="event-date">{{ event.date | formatDate }}</span>
            <span class="event-details">
              <a href="{{ rootPath }}artists/{{ event.artistSlug }}/" class="event-artist-link">{{ event.artistName }}</a>
              <span class="event-separator">-</span>
              {% if event.name %}<span class="event-name-light">{{ event.name }}</span>{% endif %}
              {% if event.type == 'festival' %}<span class="event-badge festival-badge">Festival</span>{% endif %}
              {% if event.venueName %}<span class="event-venue">{{ event.venueName }}</span>{% endif %}
              {% if event.cityName or event.countryName %}
                <span class="event-location">{{ event.cityName }}{% if event.cityName and event.countryName %}, {% endif %}{{ event.countryName }}</span>
              {% endif %}
              {% if event.eventUrl %}<a href="{{ event.eventUrl }}" target="_blank" rel="noopener noreferrer" class="event-tickets"><i class="fa-solid fa-ticket"></i> Tickets</a>{% endif %}
            </span>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  <section id="about" class="section about-section">
    <div class="section-inner">
      <h2>About Us</h2>
      {% if aboutHtml %}
        <div class="prose">{{ aboutHtml | safe }}</div>
      {% else %}
        <div class="about-placeholder prose">
          <p>Independent music label.</p>
          <div class="social-links">
            {% if social.bandcamp %}<a href="{{ social.bandcamp }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-bandcamp"></i> Bandcamp</a>{% endif %}
            {% if social.spotify %}<a href="{{ social.spotify }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-spotify"></i> Spotify</a>{% endif %}
            {% if social.soundcloud %}<a href="{{ social.soundcloud }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-soundcloud"></i> SoundCloud</a>{% endif %}
            {% if social.youtube %}<a href="{{ social.youtube }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-youtube"></i> YouTube</a>{% endif %}
            {% if social.instagram %}<a href="{{ social.instagram }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-instagram"></i> Instagram</a>{% endif %}
            {% if social.facebook %}<a href="{{ social.facebook }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-facebook"></i> Facebook</a>{% endif %}
            {% if social.tiktok %}<a href="{{ social.tiktok }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-tiktok"></i> TikTok</a>{% endif %}
            {% if social.twitter %}<a href="{{ social.twitter }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-x-twitter"></i> X / Twitter</a>{% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </section>

{% endblock %}
