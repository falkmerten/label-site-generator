{% extends "base.njk" %}

{% block title %}{{ artist.name }} — {{ labelName }}{% endblock %}
{% block title2 %}{{ artist.name }} — {{ labelName }}{% endblock %}

{% block metaDescription %}{% if artist.description %}{{ artist.description | truncate(155) }}{% else %}{{ artist.name }} on {{ labelName }} — discography, biography and more.{% endif %}{% endblock %}
{% block ogType %}music.musician{% endblock %}
{% block ogDescription %}{% if artist.description %}{{ artist.description | truncate(155) }}{% else %}{{ artist.name }} on {{ labelName }} — discography, biography and more.{% endif %}{% endblock %}
{% block twitterTitle %}{{ artist.name }} — {{ labelName }}{% endblock %}
{% block twitterDescription %}{% if artist.description %}{{ artist.description | truncate(155) }}{% else %}{{ artist.name }} on {{ labelName }} — discography, biography and more.{% endif %}{% endblock %}

{% block ogImage %}
  {% if artist.photo %}
    {% if artist.photo | isLocal %}
      {% if siteUrl %}<meta property="og:image" content="{{ siteUrl }}artists/{{ artist.slug }}/{{ artist.photo }}">{% endif %}
    {% else %}
      <meta property="og:image" content="{{ artist.photo }}">
    {% endif %}
  {% elif siteUrl %}
    <meta property="og:image" content="{{ siteUrl }}banner.jpg">
  {% endif %}
{% endblock %}
{% block twitterImage %}
  {% if artist.photo %}
    {% if artist.photo | isLocal %}
      {% if siteUrl %}<meta name="twitter:image" content="{{ siteUrl }}artists/{{ artist.slug }}/{{ artist.photo }}">{% endif %}
    {% else %}
      <meta name="twitter:image" content="{{ artist.photo }}">
    {% endif %}
  {% elif siteUrl %}
    <meta name="twitter:image" content="{{ siteUrl }}banner.jpg">
  {% endif %}
{% endblock %}

{% block jsonLd %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MusicGroup",
  "name": {{ artist.name | dump | safe }},
  {% if artist.description %}"description": {{ artist.description | dump | safe }},{% endif %}
  {% if canonicalUrl %}"url": {{ canonicalUrl | dump | safe }},{% endif %}
  {% if artist.streamingLinks and artist.streamingLinks.spotify %}"sameAs": [{{ artist.streamingLinks.spotify | dump | safe }}],{% endif %}
  "album": [
    {% for album in artist.albums %}
    {
      "@type": "MusicAlbum",
      "name": {{ album.title | dump | safe }}{% if album.releaseDate %},
      "datePublished": "{{ album.releaseDate | truncate(10, true, '') }}"{% endif %}{% if siteUrl %},
      "url": {{ (siteUrl + 'artists/' + artist.slug + '/' + album.slug + '/') | dump | safe }}{% endif %}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endblock %}

{% block hero %}
  {% if artist.photo %}
    {% if artist.photo | isLocal %}
      {% set artistPhotoUrl = rootPath + 'artists/' + artist.slug + '/' + artist.photo %}
    {% else %}
      {% set artistPhotoUrl = artist.photo %}
    {% endif %}
    <div class="site-hero artist-hero" style="--artist-photo: url('{{ artistPhotoUrl }}')">
      <div class="artist-hero-bg-clip">
        <div class="artist-hero-bg"></div>
      </div>
      <div class="artist-hero-overlay">
        <h1 class="artist-hero-name">{{ artist.name }}</h1>
        {% if artist.location %}<p class="artist-hero-location">{{ artist.location }}</p>{% endif %}
      </div>
      <a href="{{ rootPath }}" class="artist-hero-logo-link">
        <img src="{{ artistPhotoUrl }}" alt="{{ artist.name }}" class="site-hero-logo">
      </a>
    </div>
  {% else %}
    <div class="site-hero">
      <img src="{{ rootPath }}banner.jpg" alt="{{ labelName }}" class="site-hero-banner">
      <a href="{{ rootPath }}">
        <img src="{{ rootPath }}logo-round.png" alt="{{ labelName }} Logo" class="site-hero-logo">
      </a>
    </div>
  {% endif %}
{% endblock %}

{% block content %}
  <article class="artist-page">

    {% if not artist.photo %}
      <div class="artist-header">
        <div class="artist-header-text">
          <h1>{{ artist.name }}</h1>
          {% if artist.location %}<p class="artist-location">{{ artist.location }}</p>{% endif %}
        </div>
      </div>
    {% endif %}

    {% if artist.biography %}
      <section class="artist-bio prose">
        {{ artist.biography | safe }}
      </section>
    {% elif artist.description %}
      <section class="artist-bio prose">
        <p>{{ artist.description }}</p>
      </section>
    {% endif %}

    {% if artist.bandLinks and artist.bandLinks.length %}
      <section class="artist-links">
        <ul>
          {% for link in artist.bandLinks %}
            <li><a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-arrow-up-right-from-square"></i> {{ link.name }}</a></li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}

    {% if artist.streamingLinks %}
      <section class="streaming-links">
        <h2>Listen On</h2>
        <ul class="streaming-list">
          {% if artist.url %}<li><a href="{{ artist.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-bandcamp"></i> Bandcamp</a></li>{% endif %}
          {% if artist.streamingLinks.spotify %}<li><a href="{{ artist.streamingLinks.spotify }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-spotify"></i> Spotify</a></li>{% endif %}
          {% if artist.streamingLinks.appleMusic %}<li><a href="{{ artist.streamingLinks.appleMusic }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-apple"></i> Apple Music</a></li>{% endif %}
          {% if artist.streamingLinks.deezer %}<li><a href="{{ artist.streamingLinks.deezer }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-deezer"></i> Deezer</a></li>{% endif %}
          {% if artist.streamingLinks.amazonMusic %}<li><a href="{{ artist.streamingLinks.amazonMusic }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-amazon"></i> Amazon Music</a></li>{% endif %}
          {% if artist.streamingLinks.youtubeMusic %}<li><a href="{{ artist.streamingLinks.youtubeMusic }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-youtube"></i> YouTube Music</a></li>{% endif %}
          {% if artist.streamingLinks.tidal %}<li><a href="{{ artist.streamingLinks.tidal }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-water"></i> Tidal</a></li>{% endif %}
          {% if artist.streamingLinks.beatport %}<li><a href="{{ artist.streamingLinks.beatport }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-headphones"></i> Beatport</a></li>{% endif %}
          {% if artist.streamingLinks.soundcloud %}<li><a href="{{ artist.streamingLinks.soundcloud }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-soundcloud"></i> SoundCloud</a></li>{% endif %}
        </ul>
      </section>
    {% endif %}

    {% if artist.galleryImages and artist.galleryImages.length %}
      <section class="artist-gallery">
        <h2>Photos</h2>
        <div class="gallery-grid">
          {% for img in artist.galleryImages %}
            <button class="gallery-thumb" onclick="openLightbox('{{ rootPath }}artists/{{ artist.slug }}/images/{{ img }}')" aria-label="View photo">
              <img src="{{ rootPath }}artists/{{ artist.slug }}/images/{{ img }}" alt="{{ artist.name }}" loading="lazy">
            </button>
          {% endfor %}
        </div>
      </section>

      <!-- Lightbox -->
      <div id="lightbox" class="lightbox" onclick="closeLightbox()" role="dialog" aria-modal="true" aria-label="Photo viewer">
        <button class="lightbox-close" onclick="closeLightbox()" aria-label="Close">&times;</button>
        <button class="lightbox-prev" onclick="event.stopPropagation(); moveLightbox(-1)" aria-label="Previous">&#8249;</button>
        <img id="lightbox-img" src="" alt="{{ artist.name }}">
        <button class="lightbox-next" onclick="event.stopPropagation(); moveLightbox(1)" aria-label="Next">&#8250;</button>
      </div>
      <script>
        var _gallery = [{% for img in artist.galleryImages %}'{{ rootPath }}artists/{{ artist.slug }}/images/{{ img }}'{% if not loop.last %},{% endif %}{% endfor %}];
        var _current = 0;
        function openLightbox(src) {
          _current = _gallery.indexOf(src);
          document.getElementById('lightbox-img').src = src;
          document.getElementById('lightbox').classList.add('open');
          document.body.style.overflow = 'hidden';
        }
        function closeLightbox() {
          document.getElementById('lightbox').classList.remove('open');
          document.body.style.overflow = '';
        }
        function moveLightbox(dir) {
          _current = (_current + dir + _gallery.length) % _gallery.length;
          document.getElementById('lightbox-img').src = _gallery[_current];
        }
        document.addEventListener('keydown', function(e) {
          if (!document.getElementById('lightbox').classList.contains('open')) return;
          if (e.key === 'Escape') closeLightbox();
          if (e.key === 'ArrowLeft') moveLightbox(-1);
          if (e.key === 'ArrowRight') moveLightbox(1);
        });
      </script>
    {% endif %}

    <section class="discography">
      <h2>Discography</h2>
      {% if artist.albums and artist.albums.length %}
        <div class="release-grid">
          {% for album in artist.albums %}
            <a href="{{ album.slug }}/" class="release-card">
              {% if album.artwork | isLocal %}
                <img src="{{ album.slug }}/{{ album.artwork }}" alt="{{ album.title }}" loading="lazy">
              {% elif album.artwork %}
                <img src="{{ album.artwork }}" alt="{{ album.title }}" loading="lazy">
              {% else %}
                <img src="{{ rootPath }}artwork-placeholder.svg" alt="{{ album.title }}" loading="lazy">
              {% endif %}
              <div class="card-body">
                <span class="release-title">{{ album.title }}</span>
              </div>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <p>No releases currently available.</p>
      {% endif %}
    </section>

  </article>
{% endblock %}
