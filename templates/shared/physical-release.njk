{#
  Physical release section (format badges + buy links).
  Expects: album (with .physicalFormats, .hidePhysical, .upcoming, .bandcampPhysicalFormats,
                   .url, .discogsSellUrlVinyl, .discogsSellUrlCd, .discogsSellUrlCassette,
                   .discogsSellUrl, .discogsUrl, .customStores, .upc)
           artist (with .name)
           physicalStores, customStoreDefs, extraStores

  Logic: Format badges show what's available. Links are one per store (user picks format there).
  Bandcamp: one link (all formats on same page).
  Discogs: one link to marketplace (shows all available formats).
#}
{% set _hasDiscogsSell = album.discogsSellUrl or album.discogsSellUrlVinyl or album.discogsSellUrlCd or album.discogsSellUrlCassette %}
{% set _hasBandcampPhysical = album.bandcampPhysicalFormats and album.bandcampPhysicalFormats.length and album.url and 'bandcamp' in physicalStores %}
{% set _hasCustomStores = album.customStores and album.customStores.length %}
{% set _hasExtraStores = extraStores and extraStores.length %}
{% set _hasAmazon = 'amazon' in physicalStores and (album.upc or (artist.name and album.title)) %}
{% set _hasAnySellLink = _hasDiscogsSell or _hasBandcampPhysical or _hasCustomStores or _hasExtraStores or _hasAmazon %}
{% if album.physicalFormats and album.physicalFormats.length and not album.hidePhysical and not album.upcoming and _hasAnySellLink %}
  <section class="physical-release">
    <h2>Physical Release</h2>
    <div class="physical-formats">
      {% for format in album.physicalFormats %}
        {% if format === 'Vinyl' %}
          <span class="format-badge"><i class="fa-solid fa-record-vinyl"></i> Vinyl</span>
        {% elif format === 'CD' %}
          <span class="format-badge"><i class="fa-solid fa-compact-disc"></i> CD</span>
        {% elif format === 'Cassette' %}
          <span class="format-badge"><i class="fa-solid fa-tape"></i> Cassette</span>
        {% elif format === 'Box Set' %}
          <span class="format-badge"><i class="fa-solid fa-box"></i> Box Set</span>
        {% else %}
          <span class="format-badge"><i class="fa-solid fa-music"></i> {{ format }}</span>
        {% endif %}
      {% endfor %}
    </div>
    <ul class="physical-links">
      {# Bandcamp — one link, all formats on same page #}
      {% if _hasBandcampPhysical %}
        <li><a href="{{ album.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-bandcamp"></i> Buy on Bandcamp</a></li>
      {% endif %}
      {# Discogs — one link to master marketplace (or release marketplace as fallback) #}
      {% if 'discogs' in physicalStores and _hasDiscogsSell %}
        {% if album.discogsMasterId %}
          {% set _discogsLink = 'https://www.discogs.com/sell/list?master_id=' + album.discogsMasterId %}
        {% else %}
          {% set _discogsLink = album.discogsSellUrl or album.discogsSellUrlVinyl or album.discogsSellUrlCd or album.discogsSellUrlCassette %}
        {% endif %}
        <li><a href="{{ _discogsLink }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-store"></i> Buy on Discogs</a></li>
      {% endif %}
      {# ElasticStage #}
      {% if 'elasticstage' in physicalStores and album.customStores %}
        {% for store in album.customStores %}
          {% if store.store == 'elasticstage' %}
            <li><a href="{{ store.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-record-vinyl"></i> Buy on ElasticStage</a></li>
          {% endif %}
        {% endfor %}
      {% endif %}
      {# Other custom stores #}
      {% if album.customStores %}
        {% for store in album.customStores %}
          {% if store.store != 'elasticstage' %}
            <li><a href="{{ store.url }}" target="_blank" rel="noopener noreferrer"><i class="{{ store.icon or 'fa-solid fa-store' }}"></i> {{ store.label }}</a></li>
          {% endif %}
        {% endfor %}
      {% endif %}
      {# Custom store definitions from config #}
      {% for storeId in physicalStores %}
        {% if storeId != 'bandcamp' and storeId != 'discogs' and storeId != 'elasticstage' %}
          {% if customStoreDefs[storeId] %}
            {% set storeDef = customStoreDefs[storeId] %}
            <li><a href="{{ storeDef.url | storeUrl(artist.name, album.title) }}" target="_blank" rel="noopener noreferrer"><i class="{{ storeDef.icon }}"></i> {{ storeDef.label }}</a></li>
          {% endif %}
        {% endif %}
      {% endfor %}
      {# Extra stores (search-based) #}
      {% for store in extraStores %}
        {% if store.method == 'POST' %}
        <li>
          <form action="{{ store.url }}" method="post" target="_blank" style="display:inline">
            {% for key, val in store.params %}
              <input type="hidden" name="{{ key }}" value="{{ val | replace('{artist}', artist.name) | replace('{album}', album.title) }}">
            {% endfor %}
            <button type="submit" class="store-search-btn"><i class="{{ store.icon or 'fa-solid fa-store' }}"></i> {{ store.label }}</button>
          </form>
        </li>
        {% else %}
        <li><a href="{{ store | extraStoreSearchUrl(artist.name, album.title) }}" target="_blank" rel="noopener noreferrer"><i class="{{ store.icon or 'fa-solid fa-store' }}"></i> {{ store.label }}</a></li>
        {% endif %}
      {% endfor %}
      {# Amazon search #}
      {% if _hasAmazon %}
        <li><a href="https://www.amazon.com/s?k={{ (artist.name + ' ' + album.title) | urlencode }}&i=popular" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-amazon"></i> Search on Amazon</a></li>
      {% endif %}
    </ul>
  </section>
{% endif %}
