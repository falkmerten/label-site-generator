{#
  Physical release section (vinyl, CD, cassette badges + buy links).
  Expects: album (with .physicalFormats, .hidePhysical, .upcoming, .bandcampPhysicalFormats,
                   .url, .discogsSellUrlVinyl, .discogsSellUrlCd, .discogsSellUrlCassette,
                   .discogsSellUrl, .customStores, .upc)
           artist (with .name)
           physicalStores, customStoreDefs, extraStores
#}
{% if album.physicalFormats and album.physicalFormats.length and not album.hidePhysical and not album.upcoming %}
  <section class="physical-release">
    <h2>Physical Release</h2>
    {% if album.physicalFormats and album.physicalFormats.length %}
    <div class="physical-formats">
      {% for format in album.physicalFormats %}
        {% if format === 'Vinyl' %}
          <span class="format-badge"><i class="fa-solid fa-record-vinyl"></i> Vinyl</span>
        {% elif format === 'CD' %}
          <span class="format-badge"><i class="fa-solid fa-compact-disc"></i> CD</span>
        {% elif format === 'Cassette' %}
          <span class="format-badge"><i class="fa-solid fa-tape"></i> Cassette</span>
        {% elif format === 'Box Set' %}
          <span class="format-badge"><i class="fa-solid fa-box"></i> Box Set</span>
        {% else %}
          <span class="format-badge"><i class="fa-solid fa-music"></i> {{ format }}</span>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}
    <ul class="physical-links">
      {% if album.bandcampPhysicalFormats and album.bandcampPhysicalFormats.length and album.url %}
        {% if 'bandcamp' in physicalStores %}
          <li><a href="{{ album.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-bandcamp"></i> Buy on Bandcamp</a></li>
        {% endif %}
      {% endif %}
      {% if 'discogs' in physicalStores %}
        {% if album.discogsSellUrlVinyl %}
          <li><a href="{{ album.discogsSellUrlVinyl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-record-vinyl"></i> Buy Vinyl on Discogs</a></li>
        {% endif %}
        {% if album.discogsSellUrlCd %}
          <li><a href="{{ album.discogsSellUrlCd }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-compact-disc"></i> Buy CD on Discogs</a></li>
        {% endif %}
        {% if album.discogsSellUrlCassette %}
          <li><a href="{{ album.discogsSellUrlCassette }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-tape"></i> Buy Cassette on Discogs</a></li>
        {% endif %}
        {% if not album.discogsSellUrlVinyl and not album.discogsSellUrlCd and not album.discogsSellUrlCassette and album.discogsSellUrl %}
          {% if album.physicalFormats and album.physicalFormats.length == 1 %}
            {% if album.physicalFormats[0] == 'Vinyl' %}
          <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-record-vinyl"></i> Buy Vinyl on Discogs</a></li>
            {% elif album.physicalFormats[0] == 'CD' %}
          <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-compact-disc"></i> Buy CD on Discogs</a></li>
            {% elif album.physicalFormats[0] == 'Cassette' %}
          <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-tape"></i> Buy Cassette on Discogs</a></li>
            {% else %}
          <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-store"></i> Buy {{ album.physicalFormats[0] }} on Discogs</a></li>
            {% endif %}
          {% else %}
          <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-store"></i> Buy on Discogs</a></li>
          {% endif %}
        {% endif %}
      {% endif %}
      {% if 'elasticstage' in physicalStores %}
        {% if album.customStores %}
          {% for store in album.customStores %}
            {% if store.store == 'elasticstage' %}
              <li><a href="{{ store.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-record-vinyl"></i> Buy on ElasticStage</a></li>
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endif %}
      {% if album.customStores %}
        {% for store in album.customStores %}
          {% if store.store != 'elasticstage' %}
            <li><a href="{{ store.url }}" target="_blank" rel="noopener noreferrer"><i class="{{ store.icon or 'fa-solid fa-store' }}"></i> {{ store.label }}</a></li>
          {% endif %}
        {% endfor %}
      {% endif %}
      {% for storeId in physicalStores %}
        {% if storeId != 'bandcamp' and storeId != 'discogs' %}
          {% if customStoreDefs[storeId] %}
            {% set storeDef = customStoreDefs[storeId] %}
            <li><a href="{{ storeDef.url | storeUrl(artist.name, album.title) }}" target="_blank" rel="noopener noreferrer"><i class="{{ storeDef.icon }}"></i> {{ storeDef.label }}</a></li>
          {% endif %}
        {% endif %}
      {% endfor %}
      {% for store in extraStores %}
        {% if store.method == 'POST' %}
        <li>
          <form action="{{ store.url }}" method="post" target="_blank" style="display:inline">
            {% for key, val in store.params %}
              <input type="hidden" name="{{ key }}" value="{{ val | replace('{artist}', artist.name) | replace('{album}', album.title) }}">
            {% endfor %}
            <button type="submit" class="store-search-btn"><i class="{{ store.icon or 'fa-solid fa-store' }}"></i> {{ store.label }}</button>
          </form>
        </li>
        {% else %}
        <li><a href="{{ store | extraStoreSearchUrl(artist.name, album.title) }}" target="_blank" rel="noopener noreferrer"><i class="{{ store.icon or 'fa-solid fa-store' }}"></i> {{ store.label }}</a></li>
        {% endif %}
      {% endfor %}
      {% if 'amazon' in physicalStores and (album.upc or (artist.name and album.title)) %}
        <li><a href="https://www.amazon.com/s?k={{ (artist.name + ' ' + album.title) | urlencode }}&i=popular" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-amazon"></i> Search on Amazon</a></li>
      {% endif %}
    </ul>
  </section>
{% endif %}
