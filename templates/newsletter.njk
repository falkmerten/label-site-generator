<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
  <style type="text/css">
    body, table, td, p, a, li { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; height: auto; outline: none; text-decoration: none; }
    body { margin: 0; padding: 0; width: 100%; height: 100%; background-color: #f4f4f8; }
    a { color: #5a5a9e; }
    .wrapper { width: 100%; background-color: #f4f4f8; padding: 24px 0; }
    .container { max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; }
    .header { background-color: #0c0032; padding: 24px 32px; text-align: center; }
    .header img { max-width: 200px; height: auto; }
    .header h1 { color: #cacadb; font-family: system-ui, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; margin: 12px 0 0; }
    .hero-image { width: 100%; display: block; }
    .content { padding: 32px; font-family: system-ui, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; }
    .content h2 { color: #0c0032; font-size: 24px; font-weight: 800; margin: 0 0 8px; line-height: 1.3; }
    .content .date { color: #6b6b8a; font-size: 13px; margin: 0 0 20px; }
    .content .body-text { color: #333; font-size: 16px; line-height: 1.7; }
    .content .body-text p { margin: 0 0 16px; }
    .content .body-text a { color: #5a5a9e; text-decoration: underline; }
    .content .body-text img { max-width: 100%; height: auto; border-radius: 4px; }
    .cta-button { display: inline-block; padding: 14px 28px; background-color: #0c0032; color: #ffffff !important; font-size: 14px; font-weight: 700; text-decoration: none; border-radius: 4px; letter-spacing: 0.04em; margin: 8px 0 24px; }
    .cta-button:hover { background-color: #3a3a6e; }
    .divider { border: none; border-top: 1px solid #e8e8f0; margin: 28px 0; }
    .older-news { padding: 0 32px 32px; font-family: system-ui, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; }
    .older-news h3 { color: #0c0032; font-size: 13px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 16px; padding-bottom: 8px; border-bottom: 2px solid #0c0032; }
    .news-card { display: block; text-decoration: none; margin-bottom: 16px; border: 1px solid #e8e8f0; border-radius: 6px; overflow: hidden; }
    .news-card img { width: 100%; height: auto; display: block; }
    .news-card-body { padding: 12px 16px; }
    .news-card-title { color: #0c0032; font-size: 15px; font-weight: 700; margin: 0 0 4px; line-height: 1.3; }
    .news-card-date { color: #6b6b8a; font-size: 12px; margin: 0; }
    .social { padding: 24px 32px; text-align: center; background-color: #f4f4f8; }
    .social a { display: inline-block; margin: 0 8px; color: #0c0032; font-family: system-ui, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; font-size: 12px; font-weight: 600; text-decoration: none; letter-spacing: 0.04em; }
    .social a:hover { color: #5a5a9e; }
    .footer { background-color: #0c0032; padding: 24px 32px; text-align: center; font-family: system-ui, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif; }
    .footer p { color: #cacadb; font-size: 12px; line-height: 1.6; margin: 0 0 8px; }
    .footer a { color: #cacadb; text-decoration: underline; }
    @media only screen and (max-width: 640px) {
      .container { width: 100% !important; border-radius: 0 !important; }
      .content, .older-news { padding: 24px 20px !important; }
      .content h2 { font-size: 20px !important; }
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <table class="container" align="center" border="0" cellpadding="0" cellspacing="0" width="600">
      <!-- Header -->
      <tr>
        <td class="header">
          {% if logoUrl %}
            <a href="{{ siteUrl }}"><img src="{{ logoUrl }}" alt="{{ labelName }}" style="max-width:200px;height:auto;"></a>
          {% endif %}
          <h1>{{ labelName }}</h1>
        </td>
      </tr>

      <!-- Hero Image -->
      {% if article.heroImageUrl %}
      <tr>
        <td>
          <a href="{{ articleUrl }}"><img src="{{ article.heroImageUrl }}" alt="{{ article.title }}" class="hero-image" style="width:100%;display:block;"></a>
        </td>
      </tr>
      {% endif %}

      <!-- Main Content -->
      <tr>
        <td class="content">
          <h2>{{ article.title }}</h2>
          <p class="date">{{ article.dateFormatted }}</p>

          <div class="body-text">
            {{ article.html | safe }}
          </div>

          {% if articleUrl %}
          <div style="text-align:center;">
            <a href="{{ articleUrl }}" class="cta-button">Read on our website &rarr;</a>
          </div>
          {% endif %}
        </td>
      </tr>

      <!-- Older News -->
      {% if olderArticles and olderArticles.length %}
      <tr>
        <td>
          <hr class="divider" style="margin:0 32px;">
        </td>
      </tr>
      <tr>
        <td class="older-news">
          <h3>More from {{ labelName }}</h3>
          <table border="0" cellpadding="0" cellspacing="0" width="100%">
            <tr>
              {% for older in olderArticles %}
              <td style="width:{% if olderArticles.length == 1 %}100{% elif olderArticles.length == 2 %}50{% else %}33{% endif %}%;padding:{% if not loop.first %}0 0 0 8px{% elif not loop.last %}0 8px 0 0{% else %}0{% endif %};vertical-align:top;">
                <a href="{{ older.url }}" style="text-decoration:none;display:block;border:1px solid #e8e8f0;border-radius:6px;overflow:hidden;">
                  {% if older.imageUrl %}
                  <img src="{{ older.imageUrl }}" alt="{{ older.title }}" style="width:100%;height:auto;display:block;">
                  {% endif %}
                  <div style="padding:10px 12px;">
                    <p style="color:#0c0032;font-family:system-ui,-apple-system,'Segoe UI',Helvetica,Arial,sans-serif;font-size:13px;font-weight:700;margin:0 0 4px;line-height:1.3;">{{ older.title }}</p>
                    <p style="color:#6b6b8a;font-family:system-ui,-apple-system,'Segoe UI',Helvetica,Arial,sans-serif;font-size:11px;margin:0;">{{ older.dateFormatted }}</p>
                  </div>
                </a>
              </td>
              {% endfor %}
            </tr>
          </table>
        </td>
      </tr>
      {% endif %}

      <!-- Social Links -->
      <tr>
        <td class="social">
          {% if social.bandcamp %}<a href="{{ social.bandcamp }}">Bandcamp</a>{% endif %}
          {% if social.spotify %}<a href="{{ social.spotify }}">Spotify</a>{% endif %}
          {% if social.youtube %}<a href="{{ social.youtube }}">YouTube</a>{% endif %}
          {% if social.soundcloud %}<a href="{{ social.soundcloud }}">SoundCloud</a>{% endif %}
          {% if social.instagram %}<a href="{{ social.instagram }}">Instagram</a>{% endif %}
        </td>
      </tr>

      <!-- Footer -->
      <tr>
        <td class="footer">
          <p>&copy; {{ currentYear }} {{ labelName }}. All rights reserved.</p>
          {% if labelAddress %}<p>{{ labelAddress }}</p>{% endif %}
          <p><a href="[unsubscribe]">Unsubscribe</a></p>
        </td>
      </tr>

    </table>
  </div>
</body>
</html>
