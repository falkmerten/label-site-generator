<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
  <!--[if mso]><style>table{border-collapse:collapse;}td,th{border:0;}</style><![endif]-->
  <style type="text/css">
    body,table,td,p,a,li{-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;}
    table,td{mso-table-lspace:0pt;mso-table-rspace:0pt;}
    img{-ms-interpolation-mode:bicubic;border:0;height:auto;outline:none;text-decoration:none;}
    body{margin:0;padding:0;width:100%;height:100%;background-color:#f4f4f8;font-family:system-ui,-apple-system,'Segoe UI',Helvetica,Arial,sans-serif;}
    a{color:#5a5a9e;}
    @media only screen and (max-width:640px){
      .container{width:100%!important;border-radius:0!important;}
      .content-pad{padding:24px 20px!important;}
      .article-title{font-size:20px!important;}
      .card-cell{display:block!important;width:100%!important;padding:0 0 12px 0!important;}
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f8;">
  <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#f4f4f8;">
    <tr><td align="center" style="padding:24px 0;">

      <!-- Container -->
      <table class="container" align="center" border="0" cellpadding="0" cellspacing="0" width="600" style="max-width:600px;background-color:#ffffff;border-radius:8px;overflow:hidden;">

        <!-- Header -->
        <tr>
          <td align="center" style="background-color:#0c0032;padding:24px 32px;">
            {% if logoUrl %}<a href="{{ siteUrl }}"><img src="{{ logoUrl }}" alt="{{ labelName }}" style="max-width:160px;height:auto;border-radius:50%;"></a><br>{% endif %}
            <span style="color:#cacadb;font-size:13px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;">{{ labelName }}</span>
          </td>
        </tr>

        <!-- Hero Image -->
        {% if article.heroImageUrl %}
        <tr>
          <td><a href="{{ articleUrl }}"><img src="{{ article.heroImageUrl }}" alt="{{ article.title }}" style="width:100%;display:block;"></a></td>
        </tr>
        {% endif %}

        <!-- Article Content -->
        <tr>
          <td class="content-pad" style="padding:32px;">
            <h1 class="article-title" style="color:#0c0032;font-size:24px;font-weight:800;margin:0 0 8px;line-height:1.3;">{{ article.title }}</h1>
            <p style="color:#6b6b8a;font-size:13px;margin:0 0 24px;">{{ article.dateFormatted }}</p>
            <div style="color:#333;font-size:16px;line-height:1.7;">
              {{ article.html | safe }}
            </div>
            {% if articleUrl %}
            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin:24px 0;">
              <tr><td align="center">
                <a href="{{ articleUrl }}" style="display:inline-block;padding:14px 28px;background-color:#0c0032;color:#ffffff;font-size:14px;font-weight:700;text-decoration:none;border-radius:4px;">Read on our website &rarr;</a>
              </td></tr>
            </table>
            {% endif %}
          </td>
        </tr>

        <!-- Older News -->
        {% if olderArticles and olderArticles.length %}
        <tr>
          <td style="padding:0 32px;"><table border="0" cellpadding="0" cellspacing="0" width="100%"><tr><td style="border-top:1px solid #e8e8f0;"></td></tr></table></td>
        </tr>
        <tr>
          <td class="content-pad" style="padding:24px 32px 32px;">
            <p style="color:#0c0032;font-size:13px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;margin:0 0 16px;padding-bottom:8px;border-bottom:2px solid #0c0032;">More from {{ labelName }}</p>
            <table border="0" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                {% for older in olderArticles %}
                <td class="card-cell" width="{{ (100 / olderArticles.length) | round }}%" style="vertical-align:top;{% if not loop.first %}padding-left:8px;{% endif %}{% if not loop.last %}padding-right:8px;{% endif %}">
                  <table border="0" cellpadding="0" cellspacing="0" width="100%" style="border:1px solid #e8e8f0;border-radius:6px;overflow:hidden;">
                    {% if older.imageUrl %}
                    <tr><td><a href="{{ older.url }}"><img src="{{ older.imageUrl }}" alt="" style="width:100%;display:block;"></a></td></tr>
                    {% endif %}
                    <tr><td style="padding:10px 12px;">
                      <a href="{{ older.url }}" style="color:#0c0032;font-size:13px;font-weight:700;text-decoration:none;line-height:1.3;display:block;margin:0 0 4px;">{{ older.title }}</a>
                      <span style="color:#6b6b8a;font-size:11px;">{{ older.dateFormatted }}</span>
                    </td></tr>
                  </table>
                </td>
                {% endfor %}
              </tr>
            </table>
          </td>
        </tr>
        {% endif %}

        <!-- Social Links -->
        <tr>
          <td align="center" style="padding:20px 32px;background-color:#f4f4f8;">
            {% if social.bandcamp %}<a href="{{ social.bandcamp }}" style="display:inline-block;margin:0 8px;color:#0c0032;font-size:12px;font-weight:600;text-decoration:none;">Bandcamp</a>{% endif %}
            {% if social.spotify %}<a href="{{ social.spotify }}" style="display:inline-block;margin:0 8px;color:#0c0032;font-size:12px;font-weight:600;text-decoration:none;">Spotify</a>{% endif %}
            {% if social.youtube %}<a href="{{ social.youtube }}" style="display:inline-block;margin:0 8px;color:#0c0032;font-size:12px;font-weight:600;text-decoration:none;">YouTube</a>{% endif %}
            {% if social.soundcloud %}<a href="{{ social.soundcloud }}" style="display:inline-block;margin:0 8px;color:#0c0032;font-size:12px;font-weight:600;text-decoration:none;">SoundCloud</a>{% endif %}
            {% if social.instagram %}<a href="{{ social.instagram }}" style="display:inline-block;margin:0 8px;color:#0c0032;font-size:12px;font-weight:600;text-decoration:none;">Instagram</a>{% endif %}
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td align="center" style="background-color:#0c0032;padding:24px 32px;">
            <p style="color:#cacadb;font-size:12px;line-height:1.6;margin:0 0 8px;">&copy; {{ currentYear }} {{ labelName }}. All rights reserved.</p>
            {% if labelAddress %}<p style="color:#cacadb;font-size:11px;line-height:1.5;margin:0 0 8px;">{{ labelAddress }}</p>{% endif %}
            <p style="margin:0;"><a href="[unsubscribe]" style="color:#cacadb;font-size:12px;text-decoration:underline;">Unsubscribe</a></p>
          </td>
        </tr>

      </table>

    </td></tr>
  </table>
</body>
</html>
