{% extends "base.njk" %}

{% block title %}{{ album.title }} — {{ artist.name }} — {{ labelName }}{% endblock %}
{% block title2 %}{{ album.title }} — {{ artist.name }} — {{ labelName }}{% endblock %}

{% block metaDescription %}{% if album.description %}{{ album.description | truncate(155) }}{% else %}{{ album.title }} by {{ artist.name }} on {{ labelName }}.{% if album.releaseDate %} Released {{ album.releaseDate | formatDate }}.{% endif %}{% endif %}{% endblock %}
{% block ogType %}music.album{% endblock %}
{% block ogDescription %}{% if album.description %}{{ album.description | truncate(155) }}{% else %}{{ album.title }} by {{ artist.name }} on {{ labelName }}.{% if album.releaseDate %} Released {{ album.releaseDate | formatDate }}.{% endif %}{% endif %}{% endblock %}
{% block twitterTitle %}{{ album.title }} — {{ artist.name }}{% endblock %}
{% block twitterDescription %}{% if album.description %}{{ album.description | truncate(155) }}{% else %}{{ album.title }} by {{ artist.name }} on {{ labelName }}.{% endif %}{% endblock %}

{% block ogImage %}
  {% if album.artwork %}
    {% if album.artwork | isLocal %}
      {% if siteUrl %}<meta property="og:image" content="{{ siteUrl }}artists/{{ artist.slug }}/{{ album.slug }}/{{ album.artwork }}">{% endif %}
    {% else %}
      <meta property="og:image" content="{{ album.artwork }}">
    {% endif %}
  {% elif siteUrl %}
    <meta property="og:image" content="{{ siteUrl }}banner.jpg">
  {% endif %}
{% endblock %}
{% block twitterImage %}
  {% if album.artwork %}
    {% if album.artwork | isLocal %}
      {% if siteUrl %}<meta name="twitter:image" content="{{ siteUrl }}artists/{{ artist.slug }}/{{ album.slug }}/{{ album.artwork }}">{% endif %}
    {% else %}
      <meta name="twitter:image" content="{{ album.artwork }}">
    {% endif %}
  {% elif siteUrl %}
    <meta name="twitter:image" content="{{ siteUrl }}banner.jpg">
  {% endif %}
{% endblock %}

{% block jsonLd %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MusicAlbum",
  "name": {{ album.title | dump | safe }},
  "byArtist": {
    "@type": "MusicGroup",
    "name": {{ artist.name | dump | safe }}{% if siteUrl and not isCompilation %},
    "url": {{ (siteUrl + 'artists/' + artist.slug + '/') | dump | safe }}{% endif %}
  }{% if album.releaseDate %},
  "datePublished": "{{ album.releaseDate | truncate(10, true, '') }}"{% endif %}{% if album.upc %},
  "identifier": { "@type": "PropertyValue", "propertyID": "UPC", "value": "{{ album.upc }}" }{% endif %}{% if canonicalUrl %},
  "url": {{ canonicalUrl | dump | safe }}{% endif %}{% if album.tracks and album.tracks.length %},
  "track": [
    {% for track in album.tracks %}
    {
      "@type": "MusicRecording",
      "name": {{ track.name | dump | safe }}{% if track.duration %},
      "duration": "{{ track.duration }}"{% endif %}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]{% endif %}
}
</script>
{% endblock %}

{% block hero %}
  {% if album.artwork %}
    {% if album.artwork | isLocal %}
      {% set artworkUrl = rootPath + 'artists/' + artist.slug + '/' + album.slug + '/' + album.artwork %}
    {% else %}
      {% set artworkUrl = album.artwork %}
    {% endif %}
    <div class="site-hero artist-hero" style="--artist-photo: url('{{ artworkUrl }}')">
      <div class="artist-hero-bg-clip">
        <div class="artist-hero-bg"></div>
      </div>
      <div class="artist-hero-overlay">
        <p class="artist-hero-location"><a href="{% if isCompilation %}{{ rootPath }}releases/{% else %}{{ rootPath }}artists/{{ artist.slug }}/{% endif %}" style="color:inherit">{{ artist.name }}</a></p>
        <h1 class="artist-hero-name">{{ album.title }}</h1>
      </div>
      <a href="{% if isCompilation %}{{ rootPath }}releases/{% else %}{{ rootPath }}artists/{{ artist.slug }}/{% endif %}" class="artist-hero-logo-link">
        {% if album.artwork | isLocal %}
        <picture>
          <source srcset="{{ rootPath }}artists/{{ artist.slug }}/{{ album.slug }}/{{ album.artwork | toMobileWebp }}" media="(max-width: 640px)" type="image/webp">
          <source srcset="{{ rootPath }}artists/{{ artist.slug }}/{{ album.slug }}/{{ album.artwork | toWebp }}" type="image/webp">
          <img src="{{ artworkUrl }}" alt="{{ album.title }}" class="site-hero-logo">
        </picture>
        {% else %}
        <img src="{{ artworkUrl }}" alt="{{ album.title }}" class="site-hero-logo">
        {% endif %}
      </a>
    </div>
  {% else %}
    <div class="site-hero">
      <img src="{{ rootPath }}banner.jpg" alt="{{ labelName }}" class="site-hero-banner">
      <a href="{{ rootPath }}">
        <img src="{{ rootPath }}logo-round.png" alt="{{ labelName }} Logo" class="site-hero-logo">
      </a>
    </div>
  {% endif %}
{% endblock %}

{% block content %}
  <article class="album-page">

    <div class="album-header">
      <div class="album-header-text">
        <p class="album-artist"><a href="{% if isCompilation %}{{ rootPath }}releases/{% else %}{{ rootPath }}artists/{{ artist.slug }}/{% endif %}">{{ artist.name }}</a></p>
        {% if album.tags and album.tags.length %}
          <ul class="tags">
            {% for tag in album.tags %}
              <li class="tag">{{ tag.name or tag }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>

    {% if album.albumId and (not album.upcoming or album.tier == 'full') %}
      <section class="bandcamp-embed">
        {% if album.itemType === 'track' %}
          <iframe
            style="border: 0; width: 100%; height: 42px;"
            src="https://bandcamp.com/EmbeddedPlayer/track={{ album.albumId }}/size=small/bgcol=ffffff/linkcol=333333/transparent=true/"
            seamless></iframe>
        {% else %}
          <iframe
            style="border: 0; width: 100%; height: 42px;"
            src="https://bandcamp.com/EmbeddedPlayer/album={{ album.albumId }}/size=small/bgcol=ffffff/linkcol=333333/transparent=true/"
            seamless></iframe>
        {% endif %}
      </section>
    {% elif album.url and (not album.upcoming or album.tier == 'full') %}
      <p class="bandcamp-link"><a href="{{ album.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-bandcamp"></i> Listen on Bandcamp &rarr;</a></p>
    {% endif %}

    {% if album.presaveUrl %}
      <section class="presave-section">
        <a href="{{ album.presaveUrl }}" target="_blank" rel="noopener noreferrer" class="btn presave-btn"><i class="fa-solid fa-bell"></i> Pre-save this release</a>
      </section>
    {% endif %}

    {% if (album.streamingLinks or album.url) and (not album.upcoming or album.tier == 'full') %}
      <section class="streaming-links">
        <h2>Listen On</h2>
        <ul class="streaming-list">
          {% if album.url %}<li><a href="{{ album.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-bandcamp"></i> Bandcamp</a></li>{% endif %}
          {% if album.streamingLinks %}
            {% if album.streamingLinks.spotify %}<li><a href="{{ album.streamingLinks.spotify }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-spotify"></i> Spotify</a></li>{% endif %}
            {% if album.streamingLinks.appleMusic %}<li><a href="{{ album.streamingLinks.appleMusic }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-apple"></i> Apple Music</a></li>{% endif %}
            {% if album.streamingLinks.deezer %}<li><a href="{{ album.streamingLinks.deezer }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-deezer"></i> Deezer</a></li>{% endif %}
            {% if album.streamingLinks.amazonMusic %}<li><a href="{{ album.streamingLinks.amazonMusic }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-amazon"></i> Amazon Music</a></li>{% endif %}
            {% if album.streamingLinks.youtubeMusic %}<li><a href="{{ album.streamingLinks.youtubeMusic }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-youtube"></i> YouTube Music</a></li>{% endif %}
            {% if album.streamingLinks.tidal %}<li><a href="{{ album.streamingLinks.tidal }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-water"></i> Tidal</a></li>{% endif %}
            {% if album.streamingLinks.beatport %}<li><a href="{{ album.streamingLinks.beatport }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-headphones"></i> Beatport</a></li>{% endif %}
            {% if album.streamingLinks.soundcloud %}<li><a href="{{ album.streamingLinks.soundcloud }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-soundcloud"></i> SoundCloud</a></li>{% endif %}
          {% endif %}
        </ul>
      </section>
    {% endif %}

    {% if album.physicalFormats and album.physicalFormats.length and not album.hidePhysical and not album.upcoming %}
      <section class="physical-release">
        <h2>Physical Release</h2>
        {% if album.physicalFormats and album.physicalFormats.length %}
        <div class="physical-formats">
          {% for format in album.physicalFormats %}
            {% if format === 'Vinyl' %}
              <span class="format-badge"><i class="fa-solid fa-record-vinyl"></i> Vinyl</span>
            {% elif format === 'CD' %}
              <span class="format-badge"><i class="fa-solid fa-compact-disc"></i> CD</span>
            {% elif format === 'Cassette' %}
              <span class="format-badge"><i class="fa-solid fa-tape"></i> Cassette</span>
            {% elif format === 'Box Set' %}
              <span class="format-badge"><i class="fa-solid fa-box"></i> Box Set</span>
            {% else %}
              <span class="format-badge"><i class="fa-solid fa-music"></i> {{ format }}</span>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        <ul class="physical-links">
          {% if album.bandcampPhysicalFormats and album.bandcampPhysicalFormats.length and album.url %}
            {% if 'bandcamp' in physicalStores %}
              <li><a href="{{ album.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-bandcamp"></i> Buy on Bandcamp</a></li>
            {% endif %}
          {% endif %}
          {% if 'discogs' in physicalStores %}
            {% if album.discogsSellUrlVinyl %}
              <li><a href="{{ album.discogsSellUrlVinyl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-record-vinyl"></i> Buy Vinyl on Discogs</a></li>
            {% endif %}
            {% if album.discogsSellUrlCd %}
              <li><a href="{{ album.discogsSellUrlCd }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-compact-disc"></i> Buy CD on Discogs</a></li>
            {% endif %}
            {% if album.discogsSellUrlCassette %}
              <li><a href="{{ album.discogsSellUrlCassette }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-tape"></i> Buy Cassette on Discogs</a></li>
            {% endif %}
            {% if not album.discogsSellUrlVinyl and not album.discogsSellUrlCd and not album.discogsSellUrlCassette and album.discogsSellUrl %}
              {% if album.physicalFormats and album.physicalFormats.length == 1 %}
                {% if album.physicalFormats[0] == 'Vinyl' %}
              <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-record-vinyl"></i> Buy Vinyl on Discogs</a></li>
                {% elif album.physicalFormats[0] == 'CD' %}
              <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-compact-disc"></i> Buy CD on Discogs</a></li>
                {% elif album.physicalFormats[0] == 'Cassette' %}
              <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-tape"></i> Buy Cassette on Discogs</a></li>
                {% else %}
              <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-store"></i> Buy {{ album.physicalFormats[0] }} on Discogs</a></li>
                {% endif %}
              {% else %}
              <li><a href="{{ album.discogsSellUrl }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-store"></i> Buy on Discogs</a></li>
              {% endif %}
            {% endif %}
          {% endif %}
          {% if 'elasticstage' in physicalStores %}
            {% if album.customStores %}
              {% for store in album.customStores %}
                {% if store.store == 'elasticstage' %}
                  <li><a href="{{ store.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-record-vinyl"></i> Buy on ElasticStage</a></li>
                {% endif %}
              {% endfor %}
            {% endif %}
          {% endif %}
          {% if album.customStores %}
            {% for store in album.customStores %}
              {% if store.store != 'elasticstage' %}
                <li><a href="{{ store.url }}" target="_blank" rel="noopener noreferrer"><i class="{{ store.icon or 'fa-solid fa-store' }}"></i> {{ store.label }}</a></li>
              {% endif %}
            {% endfor %}
          {% endif %}
          {% for storeId in physicalStores %}
            {% if storeId != 'bandcamp' and storeId != 'discogs' %}
              {% if customStoreDefs[storeId] %}
                {% set storeDef = customStoreDefs[storeId] %}
                <li><a href="{{ storeDef.url | storeUrl(artist.name, album.title) }}" target="_blank" rel="noopener noreferrer"><i class="{{ storeDef.icon }}"></i> {{ storeDef.label }}</a></li>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% for store in extraStores %}
            {% if store.method == 'POST' %}
            <li>
              <form action="{{ store.url }}" method="post" target="_blank" style="display:inline">
                {% for key, val in store.params %}
                  <input type="hidden" name="{{ key }}" value="{{ val | replace('{artist}', artist.name) | replace('{album}', album.title) }}">
                {% endfor %}
                <button type="submit" class="store-search-btn"><i class="{{ store.icon or 'fa-solid fa-store' }}"></i> {{ store.label }}</button>
              </form>
            </li>
            {% else %}
            <li><a href="{{ store | extraStoreSearchUrl(artist.name, album.title) }}" target="_blank" rel="noopener noreferrer"><i class="{{ store.icon or 'fa-solid fa-store' }}"></i> {{ store.label }}</a></li>
            {% endif %}
          {% endfor %}
          {% if album.upc or (artist.name and album.title) %}
            <li><a href="https://www.amazon.com/s?k={{ (artist.name + ' ' + album.title) | urlencode }}&i=popular" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-amazon"></i> Search on Amazon</a></li>
          {% endif %}
        </ul>
      </section>
    {% endif %}

    {% if album.description %}
      <section class="album-description prose">
        <h2>About</h2>
        <p>{{ album.description | nl2br | safe }}</p>
      </section>
    {% endif %}
    {% if album.releaseDate %}
      <p class="album-release-date">{% if album.releaseDate | isFuture %}Pre-order · {{ album.releaseDate | formatDate }}{% else %}Released: {{ album.releaseDate | formatDate }}{% endif %}{% if album.catalogNumber %} · {{ album.catalogNumber }}{% endif %}{% if album.labelName %} · {% if album.labelUrl %}<a href="{{ album.labelUrl }}" target="_blank" rel="noopener noreferrer">{{ album.labelName }}</a>{% else %}{{ album.labelName }}{% endif %}{% endif %}{% if showOtherLabels and album.discogsLabel and album.discogsLabel != album.labelName %} / {% set dParts = album.discogsLabel.split(' / ') %}{% for dp in dParts %}{% if album.discogsLabelUrls and album.discogsLabelUrls[dp.trim()] %}<a href="{{ album.discogsLabelUrls[dp.trim()] }}" target="_blank" rel="noopener noreferrer">{{ dp }}</a>{% else %}{{ dp }}{% endif %}{% if not loop.last %} / {% endif %}{% endfor %}{% endif %}</p>
    {% elif album.catalogNumber %}
      <p class="album-release-date">{{ album.catalogNumber }}{% if album.labelName %} · {% if album.labelUrl %}<a href="{{ album.labelUrl }}" target="_blank" rel="noopener noreferrer">{{ album.labelName }}</a>{% else %}{{ album.labelName }}{% endif %}{% endif %}</p>
    {% endif %}

    {% if album.tracks and album.tracks.length and (not album.upcoming or album.tier == 'full') %}
      <section class="tracklist-section">
        <h2>Tracklist</h2>
        <ol class="tracklist">
          {% for track in album.tracks %}
            <li>
              <span class="track-name">{{ track.name }}</span>
              {% if track.duration %}
                <span class="track-duration">{{ track.duration }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ol>
      </section>
    {% endif %}

    {% if album.videos and album.videos.length %}
      <section class="album-videos">
        <h2>Videos</h2>
        <div class="video-grid{% if album.videos.length == 1 %} video-grid-single{% endif %}">
          {% for video in album.videos %}
            {% set videoId = video.url | youtubeId %}
            {% if videoId %}
            <div class="video-item">
              <iframe
                src="https://www.youtube.com/embed/{{ videoId }}"
                title="{{ video.title }}"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"></iframe>
              {% if video.title %}<p class="video-title">{{ video.title }}</p>{% endif %}
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% if album.notes %}
      <section class="album-notes prose">
        <h2>Notes</h2>
        {{ album.notes | safe }}
      </section>
    {% endif %}

    {% if album.credits %}
      <section class="album-credits">
        <h2>Credits</h2>
        <pre class="credits-text">{{ album.credits }}</pre>
      </section>
    {% endif %}

    {% if album.reviews %}
      <section class="album-reviews prose">
        <h2>Press</h2>
        {{ album.reviews | safe }}
      </section>
    {% endif %}

  </article>
{% endblock %}
