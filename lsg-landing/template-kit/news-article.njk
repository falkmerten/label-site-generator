{% extends "base.njk" %}

{% block title %}{{ article.title }} — {{ labelName }}{% endblock %}
{% block metaDescription %}{{ article.excerpt }}{% endblock %}
{% block ogDescription %}{{ article.excerpt }}{% endblock %}
{% block twitterTitle %}{{ article.title }}{% endblock %}
{% block twitterDescription %}{{ article.excerpt }}{% endblock %}

{% block ogImage %}
  {% if article.imageUrl %}
    {% if article.imageUrl | isLocal %}
      {% if siteUrl %}<meta property="og:image" content="{{ siteUrl }}news/{{ article.slug }}/{{ article.imageUrl }}">{% endif %}
    {% else %}
      <meta property="og:image" content="{{ article.imageUrl }}">
    {% endif %}
  {% endif %}
{% endblock %}

{% block ogType %}article{% endblock %}

{% block jsonLd %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": {{ article.title | dump | safe }},
  "description": {{ article.excerpt | dump | safe }},
  "datePublished": "{{ article.date }}"{% if siteUrl %},
  "url": {{ (siteUrl + 'news/' + article.slug + '/') | dump | safe }}{% endif %}{% if article.imageUrl %},
  "image": {% if article.imageUrl | isLocal %}{{ (siteUrl + 'news/' + article.slug + '/' + article.imageUrl) | dump | safe }}{% else %}{{ article.imageUrl | dump | safe }}{% endif %}{% endif %},
  "publisher": {
    "@type": "Organization",
    "name": {{ labelName | dump | safe }}{% if siteUrl %},
    "url": {{ siteUrl | dump | safe }}{% endif %}
  }
}
</script>
{% endblock %}

{% block hero %}
  {% if article.imageUrl %}
    {% if article.imageUrl | isLocal %}
      {% set heroImg = rootPath + 'news/' + article.slug + '/' + article.imageUrl %}
    {% else %}
      {% set heroImg = article.imageUrl %}
    {% endif %}
    <div class="site-hero artist-hero" style="--artist-photo: url('{{ heroImg }}')">
      <div class="artist-hero-bg-clip">
        <div class="artist-hero-bg"></div>
      </div>
      <div class="artist-hero-overlay">
        <p class="artist-hero-location"><a href="{{ rootPath }}news/" style="color:inherit">News</a></p>
        <h1 class="artist-hero-name">{{ article.title }}</h1>
      </div>
      <a href="{{ rootPath }}news/" class="artist-hero-logo-link">
        <img src="{{ heroImg }}" alt="{{ article.title }}" class="site-hero-logo">
      </a>
    </div>
  {% else %}
    <div class="site-hero">
      <picture>
        <source srcset="{{ rootPath }}banner.webp" type="image/webp">
        <img src="{{ rootPath }}banner.jpg" alt="{{ labelName }}" class="site-hero-banner" fetchpriority="high">
      </picture>
      <a href="{{ rootPath }}">
        <picture>
          <source srcset="{{ rootPath }}logo-round.webp" type="image/webp">
          <img src="{{ rootPath }}logo-round.png" alt="{{ labelName }} Logo" class="site-hero-logo">
        </picture>
      </a>
    </div>
  {% endif %}
{% endblock %}

{% block content %}
  <article class="news-article-page">
    <div class="news-article-content">
      <header class="news-article-header">
        <time class="news-article-date" datetime="{{ article.date }}">{{ article.date | formatDate }}</time>
      </header>
      {% if article.imageUrl %}
        <div class="news-article-image">
          {% if article.imageUrl | isLocal %}
          <picture>
            <source srcset="{{ rootPath }}news/{{ article.slug }}/{{ article.imageUrl | toWebp }}" type="image/webp">
            <img src="{{ rootPath }}news/{{ article.slug }}/{{ article.imageUrl }}" alt="{{ article.title }}">
          </picture>
          {% else %}
          <img src="{{ article.imageUrl }}" alt="{{ article.title }}">
          {% endif %}
        </div>
      {% endif %}
      <div class="news-article-body prose">
        {{ article.html | safe }}
      </div>
      <nav class="news-article-nav">
        {% if prevArticle %}
          <a href="{{ rootPath }}news/{{ prevArticle.slug }}/" class="news-nav-prev">&larr; {{ prevArticle.title }}</a>
        {% endif %}
        {% if nextArticle %}
          <a href="{{ rootPath }}news/{{ nextArticle.slug }}/" class="news-nav-next">{{ nextArticle.title }} &rarr;</a>
        {% endif %}
      </nav>
      <div class="news-back-link">
        <a href="{{ rootPath }}news/">&larr; Back to News</a>
      </div>
    </div>
  </article>
{% endblock %}
