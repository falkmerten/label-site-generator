{% extends "base.njk" %}

{% block title %}{{ artist.name }} — {{ labelName }}{% endblock %}
{% block title2 %}{{ artist.name }} — {{ labelName }}{% endblock %}

{% block metaDescription %}{% if artist.description %}{{ artist.description | truncate(155) }}{% else %}{{ artist.name }} on {{ labelName }} — discography, biography and more.{% endif %}{% endblock %}
{% block ogType %}music.musician{% endblock %}
{% block ogDescription %}{% if artist.description %}{{ artist.description | truncate(155) }}{% else %}{{ artist.name }} on {{ labelName }} — discography, biography and more.{% endif %}{% endblock %}
{% block twitterTitle %}{{ artist.name }} — {{ labelName }}{% endblock %}
{% block twitterDescription %}{% if artist.description %}{{ artist.description | truncate(155) }}{% else %}{{ artist.name }} on {{ labelName }} — discography, biography and more.{% endif %}{% endblock %}

{% block ogImage %}
  {% if artist.photo %}
    {% if artist.photo | isLocal %}
      {% if siteUrl %}<meta property="og:image" content="{{ siteUrl }}artists/{{ artist.slug }}/{{ artist.photo }}">{% endif %}
    {% else %}
      <meta property="og:image" content="{{ artist.photo }}">
    {% endif %}
  {% elif siteUrl %}
    <meta property="og:image" content="{{ siteUrl }}banner.jpg">
  {% endif %}
{% endblock %}
{% block twitterImage %}
  {% if artist.photo %}
    {% if artist.photo | isLocal %}
      {% if siteUrl %}<meta name="twitter:image" content="{{ siteUrl }}artists/{{ artist.slug }}/{{ artist.photo }}">{% endif %}
    {% else %}
      <meta name="twitter:image" content="{{ artist.photo }}">
    {% endif %}
  {% elif siteUrl %}
    <meta name="twitter:image" content="{{ siteUrl }}banner.jpg">
  {% endif %}
{% endblock %}

{% block jsonLd %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "MusicGroup",
  "name": {{ artist.name | dump | safe }},
  {% if artist.description %}"description": {{ artist.description | dump | safe }},{% endif %}
  {% if canonicalUrl %}"url": {{ canonicalUrl | dump | safe }},{% endif %}
  {% if artist.streamingLinks and artist.streamingLinks.spotify %}"sameAs": [{{ artist.streamingLinks.spotify | dump | safe }}],{% endif %}
  "album": [
    {% for album in artist.albums %}
    {
      "@type": "MusicAlbum",
      "name": {{ album.title | dump | safe }}{% if album.releaseDate %},
      "datePublished": "{{ album.releaseDate | truncate(10, true, '') }}"{% endif %}{% if siteUrl %},
      "url": {{ (siteUrl + 'artists/' + artist.slug + '/' + album.slug + '/') | dump | safe }}{% endif %}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endblock %}

{% block hero %}
  {% if artist.photo %}
    {% if artist.photo | isLocal %}
      {% set artistPhotoUrl = rootPath + 'artists/' + artist.slug + '/' + artist.photo %}
    {% else %}
      {% set artistPhotoUrl = artist.photo %}
    {% endif %}
    <div class="site-hero artist-hero" style="--artist-photo: url('{{ artistPhotoUrl }}')">
      <div class="artist-hero-bg-clip">
        <div class="artist-hero-bg"></div>
      </div>
      <div class="artist-hero-overlay">
        <h1 class="artist-hero-name">{{ artist.name }}</h1>
        {% if artist.location %}<p class="artist-hero-location">{{ artist.location }}</p>{% endif %}
      </div>
      <a href="{{ rootPath }}" class="artist-hero-logo-link">
        {% if artist.photo | isLocal %}
        <picture>
          <source srcset="{{ rootPath }}artists/{{ artist.slug }}/{{ artist.photo | toMobileWebp }}" media="(max-width: 640px)" type="image/webp">
          <source srcset="{{ rootPath }}artists/{{ artist.slug }}/{{ artist.photo | toWebp }}" type="image/webp">
          <img src="{{ artistPhotoUrl }}" alt="{{ artist.name }}" class="site-hero-logo">
        </picture>
        {% else %}
        <img src="{{ artistPhotoUrl }}" alt="{{ artist.name }}" class="site-hero-logo">
        {% endif %}
      </a>
    </div>
  {% else %}
    <div class="site-hero">
      <img src="{{ rootPath }}banner.jpg" alt="{{ labelName }}" class="site-hero-banner">
      <a href="{{ rootPath }}">
        <img src="{{ rootPath }}logo-round.png" alt="{{ labelName }} Logo" class="site-hero-logo">
      </a>
    </div>
  {% endif %}
{% endblock %}

{% block content %}
  <article class="artist-page">

    {% if not artist.photo %}
      <div class="artist-header">
        <div class="artist-header-text">
          <h1>{{ artist.name }}</h1>
          {% if artist.location %}<p class="artist-location">{{ artist.location }}</p>{% endif %}
        </div>
      </div>
    {% endif %}

    {% if artist.biography %}
      <section class="artist-bio prose">
        {{ artist.biography | safe }}
      </section>
    {% elif artist.description %}
      <section class="artist-bio prose">
        <p>{{ artist.description }}</p>
      </section>
    {% endif %}

    {# Unified links section: non-social bandLinks first, then social links #}
    {% set hasSocial = artist.socialLinks and (artist.socialLinks.facebook or artist.socialLinks.instagram or artist.socialLinks.tiktok or artist.socialLinks.twitter or artist.socialLinks.linktree) %}
    {% if (artist.bandLinks and artist.bandLinks.length) or hasSocial %}
      <section class="artist-links">
        <ul>
          {% if artist.bandLinks %}
            {% for link in artist.bandLinks %}
              {% set linkLower = link.name | lower %}
              {% if linkLower !== 'facebook' and linkLower !== 'instagram' and linkLower !== 'tiktok' and linkLower !== 'x.com' and linkLower !== 'twitter' and linkLower !== 'linktr.ee' and linkLower !== 'soundcloud' and linkLower !== 'open.spotify.com' and linkLower !== 'youtube' %}
              <li><a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-arrow-up-right-from-square"></i> {{ link.name }}</a></li>
              {% endif %}
            {% endfor %}
          {% endif %}
          {% if artist.socialLinks %}
            {% if artist.socialLinks.facebook %}<li><a href="{{ artist.socialLinks.facebook }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-facebook"></i> Facebook</a></li>{% endif %}
            {% if artist.socialLinks.instagram %}<li><a href="{{ artist.socialLinks.instagram }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-instagram"></i> Instagram</a></li>{% endif %}
            {% if artist.socialLinks.tiktok %}<li><a href="{{ artist.socialLinks.tiktok }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-tiktok"></i> TikTok</a></li>{% endif %}
            {% if artist.socialLinks.twitter %}<li><a href="{{ artist.socialLinks.twitter }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-x-twitter"></i> X</a></li>{% endif %}
            {% if artist.socialLinks.linktree %}<li><a href="{{ artist.socialLinks.linktree }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-link"></i> Linktree</a></li>{% endif %}
          {% endif %}
        </ul>
      </section>
    {% endif %}

    {% if artist.streamingLinks %}
      <section class="streaming-links">
        <h2>Listen On</h2>
        <ul class="streaming-list">
          {% if artist.url %}<li><a href="{{ artist.url }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-bandcamp"></i> Bandcamp</a></li>{% endif %}
          {% if artist.streamingLinks.spotify %}<li><a href="{{ artist.streamingLinks.spotify }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-spotify"></i> Spotify</a></li>{% endif %}
          {% if artist.streamingLinks.appleMusic %}<li><a href="{{ artist.streamingLinks.appleMusic }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-apple"></i> Apple Music</a></li>{% endif %}
          {% if artist.streamingLinks.deezer %}<li><a href="{{ artist.streamingLinks.deezer }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-deezer"></i> Deezer</a></li>{% endif %}
          {% if artist.streamingLinks.amazonMusic %}<li><a href="{{ artist.streamingLinks.amazonMusic }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-amazon"></i> Amazon Music</a></li>{% endif %}
          {% if artist.streamingLinks.youtubeMusic %}<li><a href="{{ artist.streamingLinks.youtubeMusic }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-youtube"></i> YouTube Music</a></li>{% endif %}
          {% if artist.streamingLinks.tidal %}<li><a href="{{ artist.streamingLinks.tidal }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-water"></i> Tidal</a></li>{% endif %}
          {% if artist.streamingLinks.beatport %}<li><a href="{{ artist.streamingLinks.beatport }}" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-headphones"></i> Beatport</a></li>{% endif %}
          {% if artist.streamingLinks.soundcloud %}<li><a href="{{ artist.streamingLinks.soundcloud }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-soundcloud"></i> SoundCloud</a></li>{% endif %}
          {% if artist.streamingLinks.youtube %}<li><a href="{{ artist.streamingLinks.youtube }}" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-youtube"></i> YouTube</a></li>{% endif %}
        </ul>
      </section>
    {% endif %}

    <section class="discography">
      <h2>Discography</h2>
      {% if artist.albums and artist.albums.length %}
        <div class="release-grid">
          {% for album in artist.albums %}
            {% if album.tier == 'announce' %}
            <div class="release-card{% if album.releaseDate | isFuture %} release-coming-soon{% endif %}">
            {% else %}
            <a href="{{ album.slug }}/" class="release-card{% if album.releaseDate | isFuture %} release-coming-soon{% endif %}">
            {% endif %}
              {% if album.releaseDate | isFuture %}<span class="coming-soon-badge">Coming Soon</span>{% endif %}
              {% if album.artwork | isLocal %}
                <picture>
                  <source srcset="{{ album.slug }}/{{ album.artwork | toMobileWebp }}" media="(max-width: 640px)" type="image/webp">
                  <source srcset="{{ album.slug }}/{{ album.artwork | toWebp }}" type="image/webp">
                  <img src="{{ album.slug }}/{{ album.artwork }}" alt="{{ album.title }}" loading="lazy">
                </picture>
              {% elif album.artwork %}
                <img src="{{ album.artwork }}" alt="{{ album.title }}" loading="lazy">
              {% else %}
                <img src="{{ rootPath }}artwork-placeholder.svg" alt="{{ album.title }}" loading="lazy">
              {% endif %}
              <div class="card-body">
                <span class="release-title">{{ album.title }}</span>
                {% if album.releaseDate %}<span class="release-year">{{ album.releaseDate | formatDate }}</span>{% endif %}
                {% set formats = album | availableFormats %}
                {% if formats %}<span class="release-formats">({{ formats }})</span>{% endif %}
              </div>
            {% if album.tier == 'announce' %}
            </div>
            {% else %}
            </a>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <p>No releases currently available.</p>
      {% endif %}
    </section>

    {% if artist.galleryImages and artist.galleryImages.length %}
      <section class="artist-gallery">
        <h2>Photos</h2>
        <div class="gallery-grid">
          {% for img in artist.galleryImages %}
            <button class="gallery-thumb" onclick="openLightbox('{{ rootPath }}artists/{{ artist.slug }}/images/{{ img }}')" aria-label="View photo">
              <picture>
                <source srcset="{{ rootPath }}artists/{{ artist.slug }}/images/{{ img | toMobileWebp }}" media="(max-width: 640px)" type="image/webp">
                <source srcset="{{ rootPath }}artists/{{ artist.slug }}/images/{{ img | toWebp }}" type="image/webp">
                <img src="{{ rootPath }}artists/{{ artist.slug }}/images/{{ img }}" alt="{{ artist.name }}" loading="lazy">
              </picture>
            </button>
          {% endfor %}
        </div>
      </section>

      <!-- Lightbox -->
      <div id="lightbox" class="lightbox" onclick="closeLightbox()" role="dialog" aria-modal="true" aria-label="Photo viewer">
        <button class="lightbox-close" onclick="closeLightbox()" aria-label="Close">&times;</button>
        <button class="lightbox-prev" onclick="event.stopPropagation(); moveLightbox(-1)" aria-label="Previous">&#8249;</button>
        <img id="lightbox-img" src="" alt="{{ artist.name }}">
        <button class="lightbox-next" onclick="event.stopPropagation(); moveLightbox(1)" aria-label="Next">&#8250;</button>
      </div>
      <script>
        var _gallery = [{% for img in artist.galleryImages %}'{{ rootPath }}artists/{{ artist.slug }}/images/{{ img }}'{% if not loop.last %},{% endif %}{% endfor %}];
        var _current = 0;
        function openLightbox(src) {
          _current = _gallery.indexOf(src);
          document.getElementById('lightbox-img').src = src;
          document.getElementById('lightbox').classList.add('open');
          document.body.style.overflow = 'hidden';
        }
        function closeLightbox() {
          document.getElementById('lightbox').classList.remove('open');
          document.body.style.overflow = '';
        }
        function moveLightbox(dir) {
          _current = (_current + dir + _gallery.length) % _gallery.length;
          document.getElementById('lightbox-img').src = _gallery[_current];
        }
        document.addEventListener('keydown', function(e) {
          if (!document.getElementById('lightbox').classList.contains('open')) return;
          if (e.key === 'Escape') closeLightbox();
          if (e.key === 'ArrowLeft') moveLightbox(-1);
          if (e.key === 'ArrowRight') moveLightbox(1);
        });
      </script>
    {% endif %}

    {% if artist.events and artist.events.length %}
    <section class="upcoming-shows">
      <h2>Upcoming Shows</h2>
      {% if artist.bandsintown %}
        <div class="event-follow-cta">
          <a href="https://www.bandsintown.com/{{ artist.bandsintown.artistName | urlencode }}?came_from={{ artist.bandsintown.appId | urlencode }}&trigger=track" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-bell"></i> Follow on Bandsintown</a>
        </div>
      {% endif %}
      <div class="events-list">
        {% for event in artist.events %}
          <div class="event-row">
            <span class="event-date">{% if event.date %}{{ event.date | formatDate }}{% endif %}</span>
            <span class="event-details">
              {% if event.name %}<span class="event-name">{{ event.name }}</span>{% endif %}
              {% if event.type == 'festival' %}<span class="event-badge festival-badge">Festival</span>{% endif %}
              {% if event.venueName %}<span class="event-venue{% if not event.name and event.type != 'festival' %} event-venue-first{% endif %}">{{ event.venueName }}</span>{% endif %}
              {% if event.cityName or event.countryName %}
                <span class="event-location">{{ event.cityName }}{% if event.cityName and event.countryName %}, {% endif %}{{ event.countryName }}</span>
              {% endif %}
              {% if event.eventUrl %}
                <a href="{{ event.eventUrl }}" target="_blank" rel="noopener noreferrer" class="event-tickets"><i class="fa-solid fa-ticket"></i> Tickets</a>
              {% endif %}
              {% if event.source == 'bandsintown' and event.eventUrl %}
                {% set hasAvailableOffer = false %}
                {% for offer in event.offers %}
                  {% if offer.status == 'available' %}
                    {% set hasAvailableOffer = true %}
                  {% endif %}
                {% endfor %}
                {% if hasAvailableOffer %}
                  <a href="{{ event.eventUrl }}&trigger=rsvp_going" target="_blank" rel="noopener noreferrer" class="event-rsvp"><i class="fa-solid fa-calendar-check"></i> RSVP</a>
                {% else %}
                  <a href="{{ event.eventUrl }}&trigger=notify_me" target="_blank" rel="noopener noreferrer" class="event-notify"><i class="fa-solid fa-bell"></i> Notify Me</a>
                {% endif %}
              {% endif %}
            </span>
          </div>
        {% endfor %}
      </div>
      {% set hasBandsintownEvent = false %}
      {% for event in artist.events %}
        {% if event.source == 'bandsintown' %}{% set hasBandsintownEvent = true %}{% endif %}
      {% endfor %}
      {% set hasSongkick = artist.eventLinks and artist.eventLinks.songkick %}
      {% set sources = [] %}
      {% if hasBandsintownEvent %}{% set sources = sources.concat([{name: 'Bandsintown', url: 'https://www.bandsintown.com/'}]) %}{% endif %}
      {% if hasSongkick %}{% set sources = sources.concat([{name: 'Songkick', url: 'https://www.songkick.com/'}]) %}{% endif %}
      {% if sources.length == 0 %}{% set sources = [{name: 'Soundcharts', url: 'https://soundcharts.com/'}] %}{% endif %}
      <p class="events-attribution">Event data by {% for src in sources %}<a href="{{ src.url }}" target="_blank" rel="noopener noreferrer">{{ src.name }}</a>{% if not loop.last %} &amp; {% endif %}{% endfor %}</p>
      {% if artist.eventLinks %}
        <div class="event-more-links">
          {% if artist.eventLinks.bandsintown %}<a href="{{ artist.eventLinks.bandsintown }}" target="_blank" rel="noopener noreferrer">More dates on Bandsintown</a>{% endif %}
          {% if artist.eventLinks.songkick %}<a href="{{ artist.eventLinks.songkick }}" target="_blank" rel="noopener noreferrer">More dates on Songkick</a>{% endif %}
        </div>
      {% endif %}
    </section>
    {% endif %}

    {% if artist.bandsintown and (not artist.events or not artist.events.length) %}
    <section class="upcoming-shows">
      <h2>Upcoming Shows</h2>
      <div class="event-follow-cta">
        <a href="https://www.bandsintown.com/{{ artist.bandsintown.artistName | urlencode }}?came_from={{ artist.bandsintown.appId | urlencode }}&trigger=track" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-bell"></i> Follow on Bandsintown</a>
      </div>
      <p class="play-my-city">No upcoming shows — <a href="https://www.bandsintown.com/{{ artist.bandsintown.artistName | urlencode }}?came_from={{ artist.bandsintown.appId | urlencode }}" target="_blank" rel="noopener noreferrer">request one in your city</a></p>
    </section>
    {% endif %}

    {% if artist.bandsintown and artist.bandsintown.artist_id %}
    {% set bitSignup = artist.bandsintown.email_signup or {} %}
    {% set bitHeaderText = bitSignup.headerText or ('Sign up for ' + artist.name + ' updates') %}
    {% set bitTitle = bitSignup.title or 'Mailing List' %}
    {% set bitCtaLabel = bitSignup.ctaLabel or 'Subscribe' %}
    {% set bitBgColor = bitSignup.backgroundColor or themeSignupBg or 'rgba(255,255,255,1)' %}
    {% set bitHeaderTextColor = bitSignup.headerTextColor or themeSignupText or 'rgba(36,34,32,1)' %}
    {% set bitCtaBgColor = bitSignup.ctaBackgroundColor or themeSignupAccent or 'rgba(124,78,33,1)' %}
    {% set bitCtaFontColor = bitSignup.ctaFontColor or themeSignupButtonText or 'rgba(255,255,255,1)' %}
    {% set bitCtaBorderColor = bitSignup.ctaBorderColor or themeSignupAccent or 'rgba(124,78,33,1)' %}
    {% set bitLayout = bitSignup.layout or 'wide' %}
    {% set bitFont = bitSignup.font or 'Helvetica' %}
    {% set bitCtaBorderRadius = bitSignup.ctaBorderRadius or '8px' %}
    <section class="bandsintown-signup">
      <iframe
        src="https://bandsintown.com/artist/{{ artist.bandsintown.artist_id }}/email_signup_form?headerTextColor={{ bitHeaderTextColor | urlencode }}&backgroundColor={{ bitBgColor | urlencode }}&ctaBackgroundColor={{ bitCtaBgColor | urlencode }}&title={{ bitTitle | urlencode }}&headerTextStyle=normal&headerText={{ bitHeaderText | urlencode }}&font={{ bitFont | urlencode }}&ctaIcon=show&ctaBorderRadius={{ bitCtaBorderRadius }}&ctaBorderWidth=2px&ctaBorderColor={{ bitCtaBorderColor | urlencode }}&ctaFontColor={{ bitCtaFontColor | urlencode }}&alignment=center&emailInputField=show&ctaLabel={{ bitCtaLabel | urlencode }}&layout={{ bitLayout }}&locale=en"
        width="100%" height="280" title="Sign up for {{ artist.name }} updates"
        scrolling="no"
        loading="lazy" style="border: none; overflow: hidden; max-width: 600px; display: block; margin: 0 auto;">
      </iframe>
    </section>
    {% endif %}

  </article>
{% endblock %}
