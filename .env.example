# ══════════════════════════════════════════════════════════════════════════════
# Label Site Generator v5 — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# This file contains ONLY credentials and the Bandcamp URL.
# All other settings live in content/config.json (auto-generated on first run).
#
# Quickstart: Set BANDCAMP_URL, run `node generate.js`
# ══════════════════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────────────────

BANDCAMP_URL=https://your-label.bandcamp.com/

# ── Bandcamp API (optional, improves detection) ──────────────────────────────

# From Bandcamp label settings → API Access
# Enables connected account detection and more reliable artist discovery
BANDCAMP_CLIENT_ID=
BANDCAMP_CLIENT_SECRET=

# ── Enrichment APIs (optional) ───────────────────────────────────────────────

# Spotify — streaming links (lightweight, ~3 calls per artist)
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Soundcharts — full metadata, all platforms, UPC/ISRC (Pro only — paid subscription)
# Not available in the free version. See https://github.com/Aenaos-Records/lsg-pro
# https://developers.soundcharts.com
# SOUNDCHARTS_APP_ID=
# SOUNDCHARTS_API_KEY=

# Last.fm — artist bios, listener stats, tags, similar artists (free, unlimited)
# https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Discogs — physical formats, sell links (only used if "discogs" in stores config)
# https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# Tidal — streaming link
# https://developer.tidal.com
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=

# YouTube — video embeds, channel sync
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# ── Newsletter (optional) ────────────────────────────────────────────────────

# Provider API credentials (Sendy, Listmonk, or Keila)
# Provider selection and form config live in config.json
NEWSLETTER_API_TOKEN=
NEWSLETTER_AUTO_CAMPAIGN=false

# ── Ghost CMS (optional) ────────────────────────────────────────────────────

# When set, Ghost is the exclusive news source (local news/ as fallback)
GHOST_URL=
GHOST_CONTENT_API_KEY=

# ── Deployment (optional) ────────────────────────────────────────────────────

# AWS S3 + CloudFront static hosting
AWS_S3_BUCKET=
AWS_S3_REGION=eu-central-1
AWS_CLOUDFRONT_DISTRIBUTION_ID=
