# Bandcamp API credentials (from Settings → API Access)
BANDCAMP_CLIENT_ID=
BANDCAMP_CLIENT_SECRET=

# Label Bandcamp URL — used as fallback if API returns no artists
BANDCAMP_LABEL_URL=https://your-label.bandcamp.com/

# Label display name (shown in page titles, header, footer)
LABEL_NAME=My Label

# Label contact details (used in placeholder Imprint/Contact pages)
LABEL_EMAIL=info@your-label.com
LABEL_ADDRESS=My Label, Street 1, 12345 City (Country)
LABEL_VAT_ID=

# Extra Bandcamp artist URLs not connected to the label account (comma-separated)
EXTRA_ARTIST_URLS=

# Spotify API credentials (from https://developer.spotify.com/dashboard)
# Used to search for Spotify links during --enrich
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Spotify credentials for the label copy export script (scripts/export-label-copy.js)
# Register a separate app at https://developer.spotify.com/dashboard to keep
# rate limits isolated from the enrichment pipeline. Falls back to SPOTIFY_CLIENT_ID/SECRET.
LABEL_COPY_SPOTIFY_CLIENT_ID=
LABEL_COPY_SPOTIFY_CLIENT_SECRET=

# Soundcharts API credentials (https://developers.soundcharts.com)
# When set, Soundcharts replaces Spotify/iTunes/Deezer/Tidal as the primary enrichment source.
# Free tier: 1,000 credits/month (1 credit per API call). Full roster ~416 calls.
# For sandbox testing: set both to "soundcharts"
SOUNDCHARTS_APP_ID=
SOUNDCHARTS_API_KEY=

# MusicFetch API key via RapidAPI (https://rapidapi.com/musicfetch-musicfetch-default/api/musicfetch2)
# Used to fetch streaming links across 30+ platforms during --enrich
MUSICFETCH_RAPIDAPI_KEY=

# Discogs personal access token (from https://www.discogs.com/settings/developers)
# Used to look up physical release formats (Vinyl, CD, etc.) and Discogs links during --enrich
DISCOGS_TOKEN=

# Tidal API credentials (from https://developer.tidal.com)
# Used to fetch Tidal links during --enrich
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=

# Social links (shown in About Us placeholder and footer)
LABEL_BANDCAMP_URL=https://your-label.bandcamp.com/
LABEL_SPOTIFY_URL=
LABEL_SOUNDCLOUD_URL=
LABEL_YOUTUBE_URL=
LABEL_INSTAGRAM_URL=
LABEL_FACEBOOK_URL=
LABEL_TIKTOK_URL=
LABEL_TWITTER_URL=

# ElasticStage on-demand vinyl/CD store
# Your label page URL on ElasticStage
ELASTICSTAGE_LABEL_URL=https://elasticstage.com/your-label

# YouTube Data API v3 key — used by --sync-youtube to find videos for albums
# Get one at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Physical store links shown on album pages (comma-separated, in display order)
# Built-in: bandcamp, discogs — add custom store IDs here to include them
PHYSICAL_STORES=bandcamp,discogs,elasticstage

# Labels whose releases appear on the homepage and releases page (comma-separated)
# Releases from other labels only appear on artist pages
# Leave empty to show all releases everywhere
HOMEPAGE_LABELS=

# Custom store definitions — add one block per store
# URL supports {artist} and {album} placeholders (URL-encoded automatically)
# Example:
# STORE_ROUGHTRADEURL=https://www.roughtrade.com/search?q={artist}+{album}
# STORE_ROUGHTRADE_LABEL=Buy at Rough Trade
# STORE_ROUGHTRADE_ICON=fa-solid fa-store

# Newsletter integration (shown on homepage News section)
# Supported providers: sendy, listmonk
# If NEWSLETTER_PROVIDER is not set but NEWSLETTER_ACTION_URL is, defaults to sendy
NEWSLETTER_PROVIDER=
NEWSLETTER_ACTION_URL=
NEWSLETTER_LIST_ID=
# Sendy-specific: API key from Sendy Settings (required for Sendy provider)
NEWSLETTER_API_KEY=
# Listmonk-specific: NEWSLETTER_LIST_ID should be the list UUID (from Listmonk admin)
# Listmonk's public subscription endpoint requires no authentication
# Set to "true" for double opt-in (GDPR confirmation email)
NEWSLETTER_DOUBLE_OPTIN=true

# Auto-create newsletter campaign drafts for new news articles
# Campaigns are created as drafts — review and send manually
NEWSLETTER_AUTO_CAMPAIGN=false
NEWSLETTER_FROM_NAME=
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_REPLY_TO=
# Sendy only: brand ID (default: 1)
NEWSLETTER_BRAND_ID=1
# Listmonk only: API credentials for campaign creation (BasicAuth)
NEWSLETTER_API_USER=
NEWSLETTER_API_TOKEN=
# Must include protocol and trailing slash, e.g. https://www.your-label.com/
SITE_URL=https://www.your-label.com/

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
GA_MEASUREMENT_ID=

# AWS deployment — used by --deploy flag (node generate.js --deploy)
# Requires AWS CLI configured with appropriate credentials
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=eu-central-1
AWS_CLOUDFRONT_DISTRIBUTION_ID=

# S3 storage for sales reports — used by --sync-s3 flag
# Also auto-syncs when STORAGE_MODE=s3
STORAGE_S3_BUCKET=
STORAGE_S3_PREFIX=
STORAGE_MODE=
