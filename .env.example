# === Your Bandcamp page ===

# Bandcamp URL - just paste your Bandcamp page URL here
# Works with both label accounts and artist/band accounts
# The generator auto-detects the account type
BANDCAMP_URL=

# Bandcamp API credentials (from Settings -> API Access)
BANDCAMP_CLIENT_ID=
BANDCAMP_CLIENT_SECRET=

# === Site identity ===

SITE_NAME=My Label
SITE_EMAIL=info@my-label.com
SITE_ADDRESS=
SITE_VAT_ID=
SITE_URL=https://www.my-label.com/

# Legacy names (still work as fallbacks):
# LABEL_NAME, LABEL_EMAIL, LABEL_ADDRESS, LABEL_VAT_ID, BANDCAMP_LABEL_URL, BANDCAMP_ARTIST_URL

# Site mode override (usually not needed - auto-detected)
# label: multiple artists, logo, label template
# artist: single artist, no logo, band template
# SITE_MODE=

# Custom template directory (overrides mode-based templates)
# Templates in this directory take precedence; missing files fall back to standard templates
# SITE_TEMPLATE=my-custom-theme

# Theme selection
# standard: clean light theme (default)
# dark: dark theme with warm accents
# bandcamp: auto-colors from your Bandcamp page
SITE_THEME=standard

# Manual theme color overrides (hex, take precedence over auto-detected Bandcamp colors)
# Note: hex values MUST be quoted because # is treated as a comment in .env files
# THEME_COLOR_BACKGROUND="#1a1a2e"
# THEME_COLOR_TEXT="#e0e0e0"
# THEME_COLOR_LINK="#d4a84f"

# Alternative label names for enrichment matching (comma-separated)
# Useful when your label publishes under different names on Spotify
# Example: LABEL_ALIASES=My Label Records,My Label Music
LABEL_ALIASES=

# Extra Bandcamp artist URLs not connected to the label account (comma-separated)
EXTRA_ARTIST_URLS=

# === Enrichment APIs ===

# Spotify API credentials (from https://developer.spotify.com/dashboard)
# Used to search for Spotify links during --enrich
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Soundcharts API credentials (https://developers.soundcharts.com)
# When set, Soundcharts replaces Spotify/iTunes/Deezer/Tidal as the primary enrichment source.
# Free tier: 1,000 credits/month (1 credit per API call). Full roster ~416 calls.
# For sandbox testing: set both to "soundcharts"
SOUNDCHARTS_APP_ID=
SOUNDCHARTS_API_KEY=

# MusicFetch API key via RapidAPI (https://rapidapi.com/musicfetch-musicfetch-default/api/musicfetch2)
# Used to fetch streaming links across 30+ platforms during --enrich
MUSICFETCH_RAPIDAPI_KEY=

# Discogs personal access token (from https://www.discogs.com/settings/developers)
# Used to look up physical release formats (Vinyl, CD, etc.) and Discogs links during --enrich
DISCOGS_TOKEN=

# Tidal API credentials (from https://developer.tidal.com)
# Used to fetch Tidal links during --enrich
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=

# === Social links ===

# Bandcamp uses BANDCAMP_URL above
LABEL_SPOTIFY_URL=
LABEL_SOUNDCLOUD_URL=
LABEL_YOUTUBE_URL=
LABEL_INSTAGRAM_URL=
LABEL_FACEBOOK_URL=
LABEL_TIKTOK_URL=
LABEL_TWITTER_URL=

# === Physical stores ===

# ElasticStage on-demand vinyl/CD store
ELASTICSTAGE_LABEL_URL=https://elasticstage.com/your-label

# YouTube Data API v3 key - used by --sync-youtube to find videos for albums
# Get one at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Physical store links shown on album pages (comma-separated, in display order)
# Built-in: bandcamp, discogs - add custom store IDs here to include them
PHYSICAL_STORES=bandcamp,discogs,elasticstage

# Labels whose releases appear on the homepage and releases page (comma-separated)
# Releases from other labels only appear on artist pages
# Leave empty to show all releases everywhere
HOMEPAGE_LABELS=

# Custom store definitions - add one block per store
# URL supports {artist} and {album} placeholders (URL-encoded automatically)
# Example:
# STORE_ROUGHTRADEURL=https://www.roughtrade.com/search?q={artist}+{album}
# STORE_ROUGHTRADE_LABEL=Buy at Rough Trade
# STORE_ROUGHTRADE_ICON=fa-solid fa-store

# === Newsletter ===

# Supported providers: sendy, listmonk, keila
# If NEWSLETTER_PROVIDER is not set but NEWSLETTER_ACTION_URL is, defaults to sendy
NEWSLETTER_PROVIDER=
NEWSLETTER_ACTION_URL=
NEWSLETTER_LIST_ID=
# API credential - used by all providers:
# Sendy: API key from Sendy Settings
# Listmonk: API token (BasicAuth, also needs NEWSLETTER_API_USER)
# Keila: Bearer token from Settings -> API Keys
NEWSLETTER_API_TOKEN=
# Listmonk only: API username for BasicAuth (campaign creation)
NEWSLETTER_API_USER=
# Set to "true" for double opt-in (GDPR confirmation email)
NEWSLETTER_DOUBLE_OPTIN=true
# Keila-specific: form ID for embedded signup form (e.g. nfrm_xxxxx)
NEWSLETTER_KEILA_FORM_ID=
# Keila-specific: sender identity for campaign creation (e.g. nms_xxxxx)
NEWSLETTER_KEILA_SENDER_ID=

# Auto-create newsletter campaign drafts for new news articles
# Campaigns are created as drafts - review and send manually
NEWSLETTER_AUTO_CAMPAIGN=false
NEWSLETTER_FROM_NAME=
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_REPLY_TO=
# Sendy only: brand ID (default: 1)
NEWSLETTER_BRAND_ID=1

# === Ghost CMS (headless news) ===

# When both GHOST_URL and GHOST_CONTENT_API_KEY are set, Ghost is the EXCLUSIVE
# news source - local content/news/ files are skipped entirely.
# If Ghost API fails at build time, the generator falls back to local news files.
# Leave both empty to use only local content/news/ markdown files.
GHOST_URL=
GHOST_CONTENT_API_KEY=

# === AWS deployment ===

# Used by --deploy flag (node generate.js --deploy)
# Requires AWS CLI configured with appropriate credentials
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=eu-central-1
AWS_CLOUDFRONT_DISTRIBUTION_ID=
